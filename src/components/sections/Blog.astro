---
import { getCollection } from 'astro:content';

// 3 derniers articles publiés (tous blogs confondus, priorité guides + villes)
const all = await getCollection('articles');
const sorted = all.sort(
  (a, b) => new Date(b.data.published_at).getTime() - new Date(a.data.published_at).getTime()
);
const latest = sorted.slice(0, 3);

const blogLabels: Record<string, string> = {
  guides: 'Guide',
  villes: 'Ville',
  quartiers: 'Quartier',
};
---
<section class="si-section" aria-label="Le Guide de l'Acheteur Immobilier : articles et conseils">
  <div class="si-container">
    <div style="text-align:center;margin-bottom:3rem;" class="si-reveal">
      <h2 class="si-section-title">Le Guide de l'Acheteur</h2>
      <p class="si-section-subtitle">Nos analyses et conseils pour acheter en toute confiance.</p>
    </div>

    <div class="si-grid-3">
      {latest.map((entry) => {
        const a = entry.data;
        const href = `/blogs/${a.blog}/${a.handle}`;
        const excerpt = (a.meta_description || '').slice(0, 150);
        return (
          <a href={href} class="si-blog-card">
            {a.image?.src ? (
              <img
                src={a.image.src}
                alt={a.image.alt || a.title}
                loading="lazy"
                width="600"
                height="400"
              />
            ) : (
              <div style="width:100%;height:12rem;background:linear-gradient(135deg, var(--si-accent-light), var(--si-secondary));display:flex;align-items:center;justify-content:center;">
                <svg width="48" height="48" fill="none" viewBox="0 0 24 24" stroke="var(--si-accent)" stroke-width="1" opacity="0.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
                </svg>
              </div>
            )}
            <div class="si-blog-card-body">
              <span class="si-blog-card-category">{blogLabels[a.blog]}</span>
              <h3 class="si-blog-card-title">{a.title}</h3>
              <p class="si-blog-card-excerpt">{excerpt}</p>
            </div>
          </a>
        );
      })}
    </div>

    <div style="text-align:center;margin-top:2rem;">
      <a href="/pages/guide" class="si-btn si-btn-secondary">
        Voir tous les guides
        <svg class="si-arrow" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-7-7 7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .si-blog-card-category {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--si-accent, #3B82F6);
    margin-bottom: 0.5rem;
  }
</style>
