      environnement:{title:'Environnement',desc:'Qualit\u00e9 de l\'air (indice ATMO) et nuisances sonores (cartographie PPBE en d\u00e9cibels). Des donn\u00e9es invisibles lors d\'une visite mais qui impactent le quotidien.',tags:['Qualit\u00e9 air','Bruit','ATMO']},
      urbanisme:{title:'Urbanisme (PLU)',desc:'Zone PLU (U, AU, A, N), r\u00e8gles de constructibilit\u00e9 via le G\u00e9oportail de l\'Urbanisme (IGN). Essentiel pour savoir si tu peux agrandir ou construire.',tags:['Zone PLU','Constructibilit\u00e9','Projets']},
      taxe:{title:'Taxe fonci\u00e8re',desc:'Estimation de la taxe fonci\u00e8re annuelle (donn\u00e9es DGFIP). Un poste souvent oubli\u00e9 : 1 000 \u00e0 3 000 \u20ac/an selon les villes. Int\u00e9gr\u00e9 dans le co\u00fbt r\u00e9el de possession.',tags:['Estimation','Taux communal','Co\u00fbt annuel']},
      population:{title:'Population & revenus (INSEE)',desc:'D\u00e9mographie, revenu m\u00e9dian, taux de ch\u00f4mage et densit\u00e9. Un revenu \u00e9lev\u00e9 et un ch\u00f4mage faible sont des indicateurs de stabilit\u00e9 du march\u00e9 immobilier local.',tags:['Revenus','Ch\u00f4mage','D\u00e9mographie']},
      locatif:{title:'Rendement locatif',desc:'Rendement brut et net bas\u00e9 sur les loyers m\u00e9dians du secteur. Loyer mensuel estim\u00e9 et cash-flow pr\u00e9visionnel. Id\u00e9al pour les investisseurs.',tags:['Brut','Net','Cash-flow']},
      cout:{title:'Co\u00fbt d\'acquisition',desc:'Le vrai prix total : frais de notaire (7-8%), frais d\'agence et budget travaux selon le DPE. Sur un bien \u00e0 250 000 \u20ac, les frais annexes d\u00e9passent souvent 25 000 \u20ac.',tags:['Notaire','Travaux','Budget total']},
      historique:{title:'Historique transactions',desc:'Ventes r\u00e9elles pass\u00e9es dans le quartier (base DVF). \u00c9volution des prix au m\u00b2, comparables r\u00e9cents et tendance hausse/baisse. L\'arme de n\u00e9gociation la plus puissante.',tags:['DVF','Comparables','Tendance']},
      actus:{title:'Actualit\u00e9s locales',desc:'Infos immobili\u00e8res r\u00e9centes de la ville (Bing News). Projets urbains (tramway, ZAC, r\u00e9novation), \u00e9volutions du march\u00e9 local. Un m\u00e9tro \u00e0 proximit\u00e9 peut faire grimper les prix de 10 \u00e0 20%.',tags:['Projets urbains','March\u00e9 local','Tendances']}
    };

    var pfPills=document.querySelectorAll('#si-pricing-features .si-fpill');
    var pfDetail=document.getElementById('si-pricing-feature-detail');
    var pfIdx=0;
    var pfCounter=document.createElement('span');
    pfCounter.className='si-carousel-counter';

    function pfRender(key,dir){
      var f=pfData[key];if(!f)return;
      var slideClass=dir==='next'?'si-slide-left':dir==='prev'?'si-slide-right':'';
      pfDetail.innerHTML='<div class="si-feature-detail-inner '+(slideClass?'si-slide-enter '+slideClass:'')+'">'+'<div class="si-feature-detail-title">'+f.title+'</div>'+'<div class="si-feature-detail-desc">'+f.desc+'</div>'+'<div class="si-feature-detail-tags">'+f.tags.map(function(t){return'<span class="si-feature-detail-tag">'+t+'</span>';}).join('')+'</div>'+'</div>';
      pfCounter.textContent=(pfIdx+1)+' / '+pfKeys.length;
      var inner=pfDetail.querySelector('.si-feature-detail-inner');
      if(inner&&slideClass){requestAnimationFrame(function(){inner.classList.remove('si-slide-enter');});}
      pfPills.forEach(function(p){p.classList.remove('active');});
      var activePill=document.querySelector('#si-pricing-features .si-fpill[data-pf="'+key+'"]');
      if(activePill) activePill.classList.add('active');
    }

    function pfGo(dir){
      if(dir==='next'){pfIdx=(pfIdx+1)%pfKeys.length;}
      else{pfIdx=(pfIdx-1+pfKeys.length)%pfKeys.length;}
      pfRender(pfKeys[pfIdx],dir);
    }

    var pfPrev=document.querySelector('.si-pricing-carousel-prev');
    var pfNext=document.querySelector('.si-pricing-carousel-next');
    if(pfPrev) pfPrev.addEventListener('click',function(){pfGo('prev');});
    if(pfNext) pfNext.addEventListener('click',function(){pfGo('next');});

    var pfCarousel=document.querySelector('#si-pricing-features .si-feature-carousel');
    if(pfCarousel) pfCarousel.appendChild(pfCounter);

    pfPills.forEach(function(pill){
      pill.addEventListener('click',function(){
        var key=this.getAttribute('data-pf');
        var newIdx=pfKeys.indexOf(key);
        var dir=newIdx>pfIdx?'next':'prev';
        pfIdx=newIdx;
        pfRender(key,dir);
      });
    });

    /* Swipe support */
    var pfStartX=0,pfStartY=0;
    if(pfDetail){
      pfDetail.addEventListener('touchstart',function(e){pfStartX=e.touches[0].clientX;pfStartY=e.touches[0].clientY;},{passive:true});
      pfDetail.addEventListener('touchend',function(e){var dx=e.changedTouches[0].clientX-pfStartX;var dy=e.changedTouches[0].clientY-pfStartY;if(Math.abs(dx)>50&&Math.abs(dx)>Math.abs(dy)){if(dx<0)pfGo('next');else pfGo('prev');}},{passive:true});
    }

    pfRender(pfKeys[0]);
  })();

  /* Init on DOM ready */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCounters);
  } else {
    initCounters();
  }
})();
</script>
