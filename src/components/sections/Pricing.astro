<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Quelles donn&eacute;es contient un rapport ScoreImmo ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Chaque rapport analyse 230+ donn&eacute;es issues de 13 sources officielles : DVF, ADEME, G&eacute;orisques, INSEE, IGN, &Eacute;ducation Nationale et plus. Tu obtiens un score sur 100, le prix par rapport au march&eacute;, les risques, le DPE, le quartier, l'urbanisme et la taxe fonci&egrave;re."
      }
    },
    {
      "@type": "Question",
      "name": "Quel plan choisir ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La D&eacute;couverte (9,99 EUR) donne 5 analyses pour v&eacute;rifier quelques biens. Recherche (1 EUR le premier mois, puis 29 EUR/mois) offre 60 analyses par mois. Premium (1 EUR le premier mois, puis 79 EUR/mois) est illimit&eacute; avec PDF brand&eacute; et mode Achat/Vente, id&eacute;al pour les professionnels."
      }
    },
    {
      "@type": "Question",
      "name": "Y a-t-il un abonnement ou un renouvellement automatique ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Les formules Recherche et Premium sont des abonnements mensuels, annulables a tout moment en 1 clic. La formule D&eacute;couverte est un paiement unique sans abonnement. Tes rapports restent accessibles m&ecirc;me apr&egrave;s annulation."
      }
    },
    {
      "@type": "Question",
      "name": "D'o&ugrave; viennent les donn&eacute;es utilis&eacute;es par ScoreImmo ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "ScoreImmo utilise 13 sources de donn&eacute;es officielles fran&ccedil;aises : DVF, ADEME, G&eacute;orisques, INSEE, IGN/GPU, BAN, OpenStreetMap, &Eacute;ducation Nationale, ATMO France et plus. Toutes les donn&eacute;es sont publiques et v&eacute;rifiables."
      }
    },
    {
      "@type": "Question",
      "name": "Combien de temps prend une analyse ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Une analyse compl&egrave;te prend environ 30 secondes. Tu colles le lien d'une annonce immobili&egrave;re, et ScoreImmo importe automatiquement les donn&eacute;es, interroge les sources officielles, calcule le score et g&eacute;n&egrave;re ton rapport d&eacute;taill&eacute;."
      }
    },
    {
      "@type": "Question",
      "name": "Mes donn&eacute;es sont-elles prot&eacute;g&eacute;es ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui. ScoreImmo applique le principe de minimisation RGPD. Tu peux exporter ou supprimer tes donn&eacute;es &agrave; tout moment depuis ton profil."
      }
    }
  ]
}
</script>

