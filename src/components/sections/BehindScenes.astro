---
---
<!-- ScoreImmo - Behind the Scenes (auto-start on scroll) -->
<section class="si-section" id="si-bts" aria-label="Votre equipe invisible">
<div class="si-container" style="max-width:960px;">

<style>
.si-bts-badge{display:inline-flex;align-items:center;gap:6px;padding:5px 14px;border-radius:99px;background:rgba(59,130,246,0.06);font-size:12px;font-weight:600;color:#3B82F6;margin-bottom:12px;}
.si-bts-title{font-family:var(--si-font-heading);font-size:clamp(22px,3.5vw,32px);font-weight:700;line-height:1.2;margin-bottom:10px;letter-spacing:-0.02em;color:var(--si-foreground);}
.si-bts-gradient{background:linear-gradient(135deg,#3B82F6,#8B5CF6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.si-bts-sub{font-size:14px;color:var(--si-muted-foreground);max-width:520px;margin:0 auto 20px;line-height:1.6;}
.si-bts-sub strong{color:var(--si-foreground);}
.si-bts-sub .blue{color:#3B82F6;font-weight:600;}
.si-bts-start{padding:12px 28px;border-radius:12px;border:none;background:#3B82F6;color:#fff;font-size:14px;font-weight:600;cursor:pointer;font-family:var(--si-font-body);transition:all .2s;}
.si-bts-start:hover{background:#2563EB;transform:translateY(-1px);}
.si-bts-grid{display:grid;grid-template-columns:280px 1fr;gap:14px;margin-top:20px;}
@media(max-width:700px){.si-bts-grid{grid-template-columns:1fr;}}
.si-bts-step{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:12px;background:rgba(0,0,0,0.02);border:1px solid transparent;cursor:pointer;width:100%;text-align:left;transition:all .25s;font-family:var(--si-font-body);}
.si-bts-step.active{border-color:rgba(59,130,246,0.2);background:rgba(59,130,246,0.04);}
.si-bts-step.done{opacity:.7;}
.si-bts-step-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;background:#F1F5F9;}
.si-bts-step.active .si-bts-step-icon{background:rgba(59,130,246,0.08);}
.si-bts-step.done .si-bts-step-icon{background:rgba(22,163,74,0.08);color:#16A34A;}
.si-bts-step-name{font-size:12px;font-weight:600;color:#64748B;}
.si-bts-step.active .si-bts-step-name{color:#3B82F6;}
.si-bts-step.done .si-bts-step-name{color:#16A34A;}
.si-bts-step-role{font-size:11px;color:#94A3B8;}
.si-bts-step-time{font-size:10px;padding:1px 6px;border-radius:6px;background:rgba(0,0,0,0.04);color:#94A3B8;font-family:monospace;}
.si-bts-panel{border-radius:16px;background:#fff;border:1px solid #E2E8F0;padding:20px;min-height:360px;display:flex;flex-direction:column;box-shadow:0 2px 8px rgba(0,0,0,0.03);}
.si-bts-dp{display:flex;align-items:center;gap:8px;font-size:12px;font-family:monospace;padding:5px 8px;border-radius:6px;background:rgba(0,0,0,0.02);margin-bottom:4px;transition:all .3s;opacity:0;transform:translateX(8px);}
.si-bts-dp.vis{opacity:1;transform:translateX(0);background:rgba(59,130,246,0.04);}
.si-bts-dp-dot{width:5px;height:5px;border-radius:50%;background:#cbd5e1;flex-shrink:0;}
.si-bts-dp.vis .si-bts-dp-dot{background:#3B82F6;}
.si-bts-status{display:inline-flex;align-items:center;gap:8px;padding:6px 14px;border-radius:10px;font-size:12px;}
.si-bts-pulse{width:6px;height:6px;border-radius:50%;background:#3B82F6;animation:si-bts-p 1s ease infinite;}
@keyframes si-bts-p{0%,100%{opacity:1;}50%{opacity:.3;}}
.si-bts-bar-track{height:8px;border-radius:99px;overflow:hidden;margin-bottom:8px;}
.si-bts-bar-fill{height:100%;border-radius:99px;transition:width 1.2s ease;}
.si-bts-stats{display:grid;grid-template-columns:repeat(5,1fr);gap:6px;margin-top:24px;}
@media(max-width:600px){.si-bts-stats{grid-template-columns:repeat(3,1fr);}}
.si-bts-stat{text-align:center;padding:12px 6px;border-radius:12px;background:rgba(0,0,0,0.02);}
.si-bts-stat-val{font-size:18px;font-weight:700;font-family:monospace;letter-spacing:-0.02em;}
.si-bts-stat-lbl{font-size:10px;color:#94A3B8;margin-top:2px;}
.si-bts-sources{text-align:center;margin-top:16px;padding:14px;border-radius:12px;background:rgba(59,130,246,0.02);}
.si-bts-src{display:inline-block;padding:3px 8px;border-radius:6px;background:#fff;border:1px solid #E2E8F0;font-size:10px;color:#64748B;margin:2px;}
</style>

<div style="text-align:center;" class="si-reveal">
  <div class="si-bts-badge">Ce qui se passe quand vous cliquez sur Analyser</div>
  <div class="si-bts-title">Votre equipe (presque) invisible<br><span class="si-bts-gradient">entre en action</span></div>
  <p class="si-bts-sub">Si vous deviez faire ce travail vous-meme, comptez <strong>plus de 5 heures</strong> de recherches. ScoreImmo le fait en <span class="blue">30 secondes</span>. Meme pas le temps de se faire un cafe.</p>
  <div id="si-bts-cta"><button class="si-bts-start" onclick="siBtsStart()">Lancer la simulation</button></div>
</div>

<div id="si-bts-pipe" style="display:none;">
  <div class="si-bts-grid">
    <div id="si-bts-steps" style="display:flex;flex-direction:column;gap:4px;"></div>
    <div class="si-bts-panel" id="si-bts-detail"></div>
  </div>
</div>

<div class="si-bts-sources">
  <div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:#94A3B8;margin-bottom:6px;">9 sources officielles francaises</div>
  <div id="si-bts-srcs"></div>
  <p style="font-size:11px;color:#94A3B8;margin-top:8px;font-style:italic;max-width:440px;margin-left:auto;margin-right:auto;line-height:1.5;">Aucun concurrent ne croise autant de donnees publiques dans un seul rapport. Nos 6 analystes ne prennent jamais de pause cafe.</p>
</div>

<script>
(function(){
var T=[
{n:"Maxime",r:"Donnees de quartier",e:"\uD83C\uDFD8\uFE0F",ht:"Arpente le quartier, interroge les voisins, repere commerces et ecoles",hm:"1h30",s:["OpenStreetMap","Education Nationale","BAN"],d:["12 ecoles","8 commerces","3 lignes transport","Score : 7.2/10"],a:4},
{n:"Antoine",r:"Prix du marche",e:"\uD83D\uDCCA",ht:"Epluche les actes DVF, compare avec 50+ transactions similaires",hm:"1h15",s:["DVF (Cerema)","INSEE"],d:["Mediane : 3 420 \u20AC/m\u00B2","Ecart : -8,2%","Tendance : +2,1%/an","52 ventes"],a:6},
{n:"Lea",r:"Risques et environnement",e:"\uD83D\uDEE1\uFE0F",ht:"Consulte Georisques, verifie PPRI, cavites, radon, qualite de l'air",hm:"45min",s:["Georisques","ATMO France"],d:["Inondation : faible","Seisme : zone 2","Radon : cat. 1","8 risques"],a:5},
{n:"Karim",r:"DPE et energie",e:"\u26A1",ht:"Contacte l'ADEME, verifie le DPE, calcule le cout energetique",hm:"30min",s:["ADEME (DPE)"],d:["Classe D","198 kWh/m\u00B2/an","GES : 28 kg CO\u2082","1 440 \u20AC/an"],a:3},
{n:"Ines",r:"Urbanisme et PLU",e:"\uD83C\uDFD7\uFE0F",ht:"Se deplace en mairie, consulte le PLU, verifie la zone",hm:"40min",s:["IGN/GPU"],d:["Zone : U","Hauteur : 12m","COS : 0.8","Preemption : non"],a:4},
{n:"Clara",r:"Fiscalite et couts",e:"\uD83D\uDCB0",ht:"Estime la taxe fonciere, calcule notaire et cout total",hm:"25min",s:["DGFIP","Notaires"],d:["TF : ~1 280 \u20AC","Notaire : 17 850 \u20AC","Total : 248 350 \u20AC","Rdt : 5,2%"],a:6}
];
var ST=[{v:"30 000+",l:"lignes de code",i:"\u2328\uFE0F"},{v:"13",l:"sources",i:"\uD83C\uDFDB\uFE0F"},{v:"230+",l:"donnees",i:"\uD83D\uDCD0"},{v:"30s",l:"par rapport",i:"\u26A1"},{v:"28",l:"sources croisees",i:"\uD83D\uDD17"}];
var SRC=["DVF (notaires)","ADEME (DPE)","Georisques","INSEE","IGN/GPU","OpenStreetMap","Education Nationale","ATMO France","DGFIP"];
var act=null,done=new Set(),timer=null,triggered=false,loopC=0;

document.getElementById('si-bts-srcs').innerHTML=SRC.map(function(s){return '<span class="si-bts-src">'+s+'</span>';}).join('');

function render(){
var sc=document.getElementById('si-bts-steps');
sc.innerHTML=T.map(function(m,i){
var isA=act===i,isD=done.has(i);
var cls='si-bts-step'+(isA?' active':'')+(isD?' done':'');
return '<button class="'+cls+'" onclick="siBtsSelect('+i+')"><div class="si-bts-step-icon">'+(isD?'\u2713':m.e)+'</div><div style="flex:1;min-width:0;"><div style="display:flex;align-items:center;gap:4px;"><span class="si-bts-step-name">'+m.n+'</span><span class="si-bts-step-time">'+m.hm+'</span></div><div class="si-bts-step-role">'+m.r+'</div></div></button>';
}).join('');

var p=document.getElementById('si-bts-detail');
if(act!==null){var m=T[act];
p.innerHTML='<div style="display:flex;align-items:center;gap:10px;padding-bottom:14px;border-bottom:1px solid #E2E8F0;margin-bottom:14px;"><div style="width:40px;height:40px;border-radius:10px;background:rgba(59,130,246,0.06);display:flex;align-items:center;justify-content:center;font-size:18px;">'+m.e+'</div><div><div style="font-family:var(--si-font-heading);font-weight:600;font-size:14px;">'+m.n+' : '+m.r+'</div><div style="font-size:11px;color:#94A3B8;font-family:monospace;">'+m.s.length+' source'+(m.s.length>1?'s':'')+' · '+m.a+' verifications</div></div></div><div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px;">'+
'<div style="padding:12px;border-radius:10px;background:rgba(220,38,38,0.03);border:1px solid rgba(220,38,38,0.08);"><div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.04em;color:#DC2626;margin-bottom:4px;">Vous <span style="font-family:monospace;background:rgba(220,38,38,0.06);padding:1px 5px;border-radius:4px;font-size:10px;">'+m.hm+'</span></div><div style="font-size:12px;color:#991B1B;line-height:1.5;">'+m.ht+'</div></div>'+
'<div style="padding:12px;border-radius:10px;background:rgba(59,130,246,0.03);border:1px solid rgba(59,130,246,0.08);"><div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.04em;color:#2563EB;margin-bottom:4px;">ScoreImmo <span style="font-family:monospace;background:rgba(59,130,246,0.06);padding:1px 5px;border-radius:4px;font-size:10px;">~5 sec</span></div><div style="font-size:12px;color:#1E40AF;line-height:1.5;">'+m.a+' sources croisees. Sources : '+m.s.join(', ')+'.</div></div></div>'+
'<div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:#94A3B8;margin-bottom:6px;">Donnees extraites</div><div id="si-bts-dps">'+m.d.map(function(d,i){return '<div class="si-bts-dp" id="si-dp-'+i+'"><span class="si-bts-dp-dot"></span>'+d+'</div>';}).join('')+'</div><div style="display:flex;flex-wrap:wrap;gap:3px;margin-top:auto;padding-top:12px;">'+m.s.map(function(s){return '<span style="padding:2px 7px;border-radius:5px;background:rgba(0,0,0,0.03);font-size:10px;color:#64748B;">'+s+'</span>';}).join('')+'</div>';
m.d.forEach(function(_,i){setTimeout(function(){var el=document.getElementById('si-dp-'+i);if(el)el.classList.add('vis');},250+i*280);});
}else if(done.size===T.length){
p.innerHTML='<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;flex:1;text-align:center;"><div style="width:50px;height:50px;border-radius:50%;background:rgba(22,163,74,0.08);display:flex;align-items:center;justify-content:center;font-size:20px;color:#16A34A;margin-bottom:14px;">\u2713</div><div style="font-family:var(--si-font-heading);font-weight:700;font-size:16px;margin-bottom:4px;">Rapport genere</div><p style="font-size:13px;color:#64748B;margin-bottom:16px;">6 analystes. 9 sources. 230+ donnees.<br>En <strong style="color:#3B82F6;">30s</strong> au lieu de <strong style="color:#DC2626;">5h</strong>.</p><div style="width:100%;max-width:280px;"><div style="display:flex;justify-content:space-between;font-size:11px;margin-bottom:3px;"><span style="color:#DC2626;font-weight:500;">Si vous le faites vous-meme</span><span style="font-family:monospace;color:#DC2626;">~5h</span></div><div class="si-bts-bar-track" style="background:rgba(220,38,38,0.08);"><div class="si-bts-bar-fill" id="si-bar-h" style="width:0%;background:#DC2626;"></div></div><div style="display:flex;justify-content:space-between;font-size:11px;margin-bottom:3px;"><span style="color:#3B82F6;font-weight:500;">ScoreImmo</span><span style="font-family:monospace;color:#3B82F6;">30s</span></div><div class="si-bts-bar-track" style="background:rgba(59,130,246,0.08);"><div class="si-bts-bar-fill" id="si-bar-b" style="width:0%;background:#3B82F6;min-width:6px;"></div></div></div><button class="si-bts-start" style="margin-top:16px;font-size:12px;padding:8px 18px;" onclick="siBtsStart()">Relancer</button></div>';
requestAnimationFrame(function(){var h=document.getElementById('si-bar-h'),b=document.getElementById('si-bar-b');if(h)h.style.width='100%';setTimeout(function(){if(b)b.style.width='2%';},400);});
}}

window.siBtsSelect=function(i){if(timer){clearInterval(timer);timer=null;}act=i;render();};
window.siBtsStart=function(){
done=new Set();act=0;
document.getElementById('si-bts-pipe').style.display='block';
document.getElementById('si-bts-cta').innerHTML='<div class="si-bts-status" style="background:rgba(59,130,246,0.04);"><span class="si-bts-pulse"></span><span style="color:#64748B;">Analyse en cours...</span><span style="font-family:monospace;color:#3B82F6;font-weight:600;">1/'+T.length+'</span></div>';
render();
var step=0;
if(timer)clearInterval(timer);
timer=setInterval(function(){
step++;
if(step<T.length){done.add(step-1);act=step;
document.getElementById('si-bts-cta').innerHTML='<div class="si-bts-status" style="background:rgba(59,130,246,0.04);"><span class="si-bts-pulse"></span><span style="color:#64748B;">Analyse...</span><span style="font-family:monospace;color:#3B82F6;font-weight:600;">'+(step+1)+'/'+T.length+'</span></div>';
render();}else{done.add(step-1);act=null;
document.getElementById('si-bts-cta').innerHTML='<div class="si-bts-status" style="background:rgba(22,163,74,0.04);"><span style="color:#16A34A;font-weight:500;">Rapport complet</span></div>';
render();clearInterval(timer);timer=null;loopC++;if(loopC<1){setTimeout(siBtsStart,3000);}}
},4500);
};

// Auto-start on scroll
var obs=new IntersectionObserver(function(entries){
if(entries[0].isIntersecting&&!triggered){triggered=true;siBtsStart();}
},{threshold:0.3});
var el=document.getElementById('si-bts');
if(el)obs.observe(el);
})();
</script>

</div>
</section>
