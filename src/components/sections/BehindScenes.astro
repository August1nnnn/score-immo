---
// ScoreImmo - Votre équipe invisible (pipeline interactif, auto-start au scroll)
// Refonte 2026-06-03 : styles globaux prefixes #si-bts (le DOM est injecte en JS,
// donc les styles scopes Astro ne s'appliquaient pas -> colonne analystes "cassee").
// DA preservee (bleu #3B82F6, glass, Inter/DM Sans). Accents FR complets.
---
<section class="si-section" id="si-bts" aria-label="Votre équipe invisible">
<div class="si-container" style="max-width:1040px;">

  <div class="si-bts-head si-reveal">
    <span class="si-bts-badge"><span class="si-bts-badge-dot"></span>Ce qui se passe quand vous cliquez sur Analyser</span>
    <h2 class="si-bts-title">Votre équipe (presque) invisible<br><span class="si-bts-gradient">entre en action</span></h2>
    <p class="si-bts-sub">Si vous deviez faire ce travail vous-même, comptez <strong>plus de 5 heures</strong> de recherches. ScoreImmo le fait en <span class="si-bts-blue">30 secondes</span>. Même pas le temps de se faire un café.</p>
    <div id="si-bts-cta"><button class="si-bts-start" type="button" onclick="siBtsStart()">Lancer la simulation</button></div>
  </div>

  <div id="si-bts-pipe" class="si-bts-pipe">
    <div class="si-bts-grid">
      <div id="si-bts-steps" class="si-bts-steps"></div>
      <div class="si-bts-panel" id="si-bts-detail"></div>
    </div>
  </div>

  <div class="si-bts-strip" id="si-bts-strip"></div>

  <div class="si-bts-sources">
    <div class="si-bts-sources-label">10 sources officielles françaises</div>
    <div id="si-bts-srcs"></div>
    <p class="si-bts-sources-note">Aucun concurrent ne croise autant de données publiques dans un seul rapport. Nos 6 analystes ne prennent jamais de pause café.</p>
  </div>

</div>

<script>
(function(){
var T=[
{n:"Maxime",r:"Données de quartier",e:"🏘️",ht:"Arpente le quartier, interroge les voisins, repère commerces et écoles",hm:"1h30",s:["OpenStreetMap","Éducation Nationale","BAN"],d:["12 écoles","8 commerces","3 lignes transport","Score : 7,2/10"],a:4},
{n:"Antoine",r:"Prix du marché",e:"📊",ht:"Épluche les actes DVF, compare avec 50+ transactions similaires",hm:"1h15",s:["DVF (Cerema)","INSEE"],d:["Médiane : 3 420 €/m²","Écart : -8,2%","Tendance : +2,1%/an","52 ventes"],a:6},
{n:"Léa",r:"Risques et environnement",e:"🛡️",ht:"Consulte Géorisques, vérifie PPRI, cavités, radon, qualité de l'air",hm:"45min",s:["Géorisques","ATMO France"],d:["Inondation : faible","Séisme : zone 2","Radon : cat. 1","8 risques"],a:5},
{n:"Karim",r:"DPE et énergie",e:"⚡",ht:"Contacte l'ADEME, vérifie le DPE, calcule le coût énergétique",hm:"30min",s:["ADEME (DPE)"],d:["Classe D","198 kWh/m²/an","GES : 28 kg CO₂","1 440 €/an"],a:3},
{n:"Inès",r:"Urbanisme et PLU",e:"🏗️",ht:"Se déplace en mairie, consulte le PLU, vérifie la zone",hm:"40min",s:["IGN/GPU"],d:["Zone : U","Hauteur : 12m","COS : 0,8","Préemption : non"],a:4},
{n:"Clara",r:"Fiscalité et coûts",e:"💰",ht:"Estime la taxe foncière, calcule notaire et coût total",hm:"25min",s:["DGFIP","Notaires"],d:["TF : ~1 280 €","Notaire : 17 850 €","Total : 248 350 €","Rendement : 5,2%"],a:6}
];
var ST=[{v:"6",l:"analystes"},{v:"9",l:"sources officielles"},{v:"230+",l:"données croisées"},{v:"30s",l:"par rapport"},{v:"5h",l:"économisées"}];
var SRC=["DVF (notaires)","ADEME (DPE)","Géorisques","INSEE","IGN/GPU","OpenStreetMap","Éducation Nationale","ATMO France","DGFIP"];
var act=null,done=new Set(),timer=null,triggered=false,loopC=0;

document.getElementById('si-bts-srcs').innerHTML=SRC.map(function(s){return '<span class="si-bts-src">'+s+'</span>';}).join('');
document.getElementById('si-bts-strip').innerHTML=ST.map(function(s){return '<div class="si-bts-stat"><div class="si-bts-stat-val">'+s.v+'</div><div class="si-bts-stat-lbl">'+s.l+'</div></div>';}).join('');

function render(){
var sc=document.getElementById('si-bts-steps');
sc.innerHTML=T.map(function(m,i){
var isA=act===i,isD=done.has(i);
var cls='si-bts-step'+(isA?' active':'')+(isD?' done':'');
return '<button type="button" class="'+cls+'" onclick="siBtsSelect('+i+')"><div class="si-bts-step-icon">'+(isD?'✓':m.e)+'</div><div class="si-bts-step-body"><div class="si-bts-step-top"><span class="si-bts-step-name">'+m.n+'</span><span class="si-bts-step-time">'+m.hm+'</span></div><div class="si-bts-step-role">'+m.r+'</div></div></button>';
}).join('');

var p=document.getElementById('si-bts-detail');
if(act!==null){var m=T[act];
p.innerHTML='<div class="si-bts-dh"><div class="si-bts-dh-icon">'+m.e+'</div><div><div class="si-bts-dh-name">'+m.n+' : '+m.r+'</div><div class="si-bts-dh-meta">'+m.s.length+' source'+(m.s.length>1?'s':'')+' · '+m.a+' vérifications</div></div></div>'+
'<div class="si-bts-vs">'+
'<div class="si-bts-vs-card si-bts-vs-you"><div class="si-bts-vs-label">Vous <span class="si-bts-vs-time">'+m.hm+'</span></div><div class="si-bts-vs-txt">'+m.ht+'</div></div>'+
'<div class="si-bts-vs-card si-bts-vs-si"><div class="si-bts-vs-label">ScoreImmo <span class="si-bts-vs-time">~5 s</span></div><div class="si-bts-vs-txt">'+m.a+' sources croisées. Sources : '+m.s.join(', ')+'.</div></div></div>'+
'<div class="si-bts-dp-label">Données extraites</div><div id="si-bts-dps">'+m.d.map(function(d,i){return '<div class="si-bts-dp" id="si-dp-'+i+'"><span class="si-bts-dp-dot"></span>'+d+'</div>';}).join('')+'</div>'+
'<div class="si-bts-srcrow">'+m.s.map(function(s){return '<span class="si-bts-srctag">'+s+'</span>';}).join('')+'</div>';
m.d.forEach(function(_,i){setTimeout(function(){var el=document.getElementById('si-dp-'+i);if(el)el.classList.add('vis');},250+i*260);});
}else if(done.size===T.length){
p.innerHTML='<div class="si-bts-final"><div class="si-bts-final-check">✓</div><div class="si-bts-final-title">Rapport généré</div><p class="si-bts-final-sub">6 analystes. 10 sources. 230+ données.<br>En <strong class="si-bts-blue">30 s</strong> au lieu de <strong class="si-bts-red">5 h</strong>.</p><div class="si-bts-bars"><div class="si-bts-bar-row"><span class="si-bts-red">Si vous le faites vous-même</span><span class="si-bts-mono si-bts-red">~5 h</span></div><div class="si-bts-bar-track si-bts-bar-track-red"><div class="si-bts-bar-fill" id="si-bar-h" style="width:0%;background:#DC2626;"></div></div><div class="si-bts-bar-row"><span class="si-bts-blue">ScoreImmo</span><span class="si-bts-mono si-bts-blue">30 s</span></div><div class="si-bts-bar-track si-bts-bar-track-blue"><div class="si-bts-bar-fill" id="si-bar-b" style="width:0%;background:#3B82F6;min-width:6px;"></div></div></div><button type="button" class="si-bts-start si-bts-start-sm" onclick="siBtsStart()">Relancer la simulation</button></div>';
requestAnimationFrame(function(){var h=document.getElementById('si-bar-h'),b=document.getElementById('si-bar-b');if(h)h.style.width='100%';setTimeout(function(){if(b)b.style.width='2%';},400);});
}}

window.siBtsSelect=function(i){if(timer){clearInterval(timer);timer=null;}act=i;render();};
window.siBtsStart=function(){
done=new Set();act=0;
document.getElementById('si-bts-pipe').classList.add('on');
document.getElementById('si-bts-cta').innerHTML='<div class="si-bts-status"><span class="si-bts-pulse"></span><span class="si-bts-status-txt">Analyse en cours...</span><span class="si-bts-mono si-bts-status-n">1/'+T.length+'</span></div>';
render();
var step=0;
if(timer)clearInterval(timer);
timer=setInterval(function(){
step++;
if(step<T.length){done.add(step-1);act=step;
document.getElementById('si-bts-cta').innerHTML='<div class="si-bts-status"><span class="si-bts-pulse"></span><span class="si-bts-status-txt">Analyse...</span><span class="si-bts-mono si-bts-status-n">'+(step+1)+'/'+T.length+'</span></div>';
render();}else{done.add(step-1);act=null;
document.getElementById('si-bts-cta').innerHTML='<div class="si-bts-status si-bts-status-done"><span class="si-bts-status-txt-done">Rapport complet</span></div>';
render();clearInterval(timer);timer=null;loopC++;if(loopC<1){setTimeout(siBtsStart,3200);}}
},3800);
};

var obs=new IntersectionObserver(function(entries){
if(entries[0].isIntersecting&&!triggered){triggered=true;siBtsStart();}
},{threshold:0.3});
var el=document.getElementById('si-bts');
if(el)obs.observe(el);
})();
</script>

<style is:global>
#si-bts{position:relative;}
#si-bts .si-bts-head{text-align:center;max-width:640px;margin:0 auto;}
#si-bts .si-bts-badge{display:inline-flex;align-items:center;gap:7px;padding:6px 15px;border-radius:99px;background:var(--si-accent-light);font-size:12px;font-weight:600;color:var(--si-accent);margin-bottom:14px;letter-spacing:-0.01em;}
#si-bts .si-bts-badge-dot{width:6px;height:6px;border-radius:50%;background:var(--si-accent);box-shadow:0 0 0 3px rgba(59,130,246,0.18);}
#si-bts .si-bts-title{font-family:var(--si-font-heading);font-size:clamp(24px,4vw,38px);font-weight:800;line-height:1.12;margin:0 0 12px;letter-spacing:-0.025em;color:var(--si-foreground);}
#si-bts .si-bts-gradient{background:linear-gradient(120deg,#3B82F6,#1D4ED8);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:transparent;}
#si-bts .si-bts-sub{font-size:15px;color:var(--si-muted-foreground);max-width:540px;margin:0 auto 22px;line-height:1.6;}
#si-bts .si-bts-sub strong{color:var(--si-foreground);font-weight:600;}
#si-bts .si-bts-blue{color:var(--si-accent);font-weight:600;}
#si-bts .si-bts-red{color:var(--si-destructive);font-weight:600;}
#si-bts .si-bts-mono{font-family:ui-monospace,SFMono-Regular,Menlo,monospace;}

#si-bts .si-bts-start{padding:13px 30px;border-radius:13px;border:none;background:var(--si-accent);color:#fff;font-size:14px;font-weight:600;cursor:pointer;font-family:var(--si-font-body);transition:transform .18s ease,box-shadow .18s ease,background .18s ease;box-shadow:0 8px 22px rgba(59,130,246,0.25);}
#si-bts .si-bts-start:hover{background:#2563EB;transform:translateY(-2px);box-shadow:0 12px 28px rgba(59,130,246,0.32);}
#si-bts .si-bts-start-sm{margin-top:18px;font-size:12.5px;padding:9px 20px;box-shadow:0 6px 16px rgba(59,130,246,0.22);}

#si-bts .si-bts-status{display:inline-flex;align-items:center;gap:9px;padding:9px 18px;border-radius:12px;font-size:13px;background:var(--si-accent-light);}
#si-bts .si-bts-status-txt{color:var(--si-muted-foreground);}
#si-bts .si-bts-status-n{color:var(--si-accent);font-weight:600;}
#si-bts .si-bts-status-done{background:rgba(22,163,74,0.08);}
#si-bts .si-bts-status-txt-done{color:var(--si-success);font-weight:600;}
#si-bts .si-bts-pulse{width:7px;height:7px;border-radius:50%;background:var(--si-accent);animation:si-bts-p 1s ease infinite;}
@keyframes si-bts-p{0%,100%{opacity:1;}50%{opacity:.25;}}

#si-bts .si-bts-pipe{max-height:0;opacity:0;overflow:hidden;transition:max-height .5s ease,opacity .4s ease;}
#si-bts .si-bts-pipe.on{max-height:1400px;opacity:1;}
#si-bts .si-bts-grid{display:grid;grid-template-columns:300px 1fr;gap:16px;margin-top:24px;align-items:start;}
#si-bts .si-bts-steps{display:flex;flex-direction:column;gap:8px;}

#si-bts .si-bts-step{display:flex;align-items:center;gap:11px;padding:11px 13px;border-radius:14px;background:var(--si-card);border:1px solid var(--si-border);cursor:pointer;width:100%;text-align:left;transition:transform .2s ease,border-color .2s ease,background .2s ease,box-shadow .2s ease;font-family:var(--si-font-body);box-shadow:0 1px 2px rgba(0,0,0,0.03);}
#si-bts .si-bts-step:hover{transform:translateX(2px);box-shadow:0 6px 18px rgba(0,0,0,0.06);}
#si-bts .si-bts-step.active{border-color:rgba(59,130,246,0.45);background:var(--si-accent-light);box-shadow:0 8px 22px rgba(59,130,246,0.14);}
#si-bts .si-bts-step.done{opacity:.78;}
#si-bts .si-bts-step-icon{width:40px;height:40px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;background:var(--si-muted);transition:background .2s ease,color .2s ease;}
#si-bts .si-bts-step.active .si-bts-step-icon{background:rgba(59,130,246,0.12);}
#si-bts .si-bts-step.done .si-bts-step-icon{background:rgba(22,163,74,0.12);color:var(--si-success);font-weight:700;}
#si-bts .si-bts-step-body{flex:1;min-width:0;}
#si-bts .si-bts-step-top{display:flex;align-items:center;gap:7px;}
#si-bts .si-bts-step-name{font-size:13px;font-weight:600;color:var(--si-foreground);}
#si-bts .si-bts-step.active .si-bts-step-name{color:var(--si-accent);}
#si-bts .si-bts-step.done .si-bts-step-name{color:var(--si-success);}
#si-bts .si-bts-step-time{font-size:10px;padding:2px 7px;border-radius:7px;background:var(--si-muted);color:var(--si-muted-foreground);font-family:ui-monospace,SFMono-Regular,Menlo,monospace;}
#si-bts .si-bts-step-role{font-size:11.5px;color:var(--si-muted-foreground);margin-top:2px;}

#si-bts .si-bts-panel{border-radius:18px;background:var(--si-card);border:1px solid var(--si-border);padding:22px;min-height:380px;display:flex;flex-direction:column;box-shadow:var(--si-glass-shadow);}
#si-bts .si-bts-dh{display:flex;align-items:center;gap:11px;padding-bottom:15px;border-bottom:1px solid var(--si-border);margin-bottom:15px;}
#si-bts .si-bts-dh-icon{width:42px;height:42px;border-radius:11px;background:var(--si-accent-light);display:flex;align-items:center;justify-content:center;font-size:19px;flex-shrink:0;}
#si-bts .si-bts-dh-name{font-family:var(--si-font-heading);font-weight:700;font-size:14.5px;color:var(--si-foreground);}
#si-bts .si-bts-dh-meta{font-size:11px;color:#94A3B8;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;margin-top:2px;}
#si-bts .si-bts-vs{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:16px;}
#si-bts .si-bts-vs-card{padding:12px 13px;border-radius:12px;}
#si-bts .si-bts-vs-you{background:rgba(220,38,38,0.035);border:1px solid rgba(220,38,38,0.1);}
#si-bts .si-bts-vs-si{background:rgba(59,130,246,0.04);border:1px solid rgba(59,130,246,0.1);}
#si-bts .si-bts-vs-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;margin-bottom:5px;display:flex;align-items:center;gap:6px;}
#si-bts .si-bts-vs-you .si-bts-vs-label{color:var(--si-destructive);}
#si-bts .si-bts-vs-si .si-bts-vs-label{color:#2563EB;}
#si-bts .si-bts-vs-time{font-family:ui-monospace,SFMono-Regular,Menlo,monospace;padding:1px 6px;border-radius:5px;font-size:10px;font-weight:600;}
#si-bts .si-bts-vs-you .si-bts-vs-time{background:rgba(220,38,38,0.08);}
#si-bts .si-bts-vs-si .si-bts-vs-time{background:rgba(59,130,246,0.08);}
#si-bts .si-bts-vs-txt{font-size:12px;line-height:1.5;}
#si-bts .si-bts-vs-you .si-bts-vs-txt{color:#991B1B;}
#si-bts .si-bts-vs-si .si-bts-vs-txt{color:#1E40AF;}
#si-bts .si-bts-dp-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:#94A3B8;margin-bottom:7px;}
#si-bts .si-bts-dp{display:flex;align-items:center;gap:8px;font-size:12px;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;padding:6px 9px;border-radius:7px;background:rgba(0,0,0,0.02);margin-bottom:4px;transition:opacity .3s ease,transform .3s ease,background .3s ease;opacity:0;transform:translateX(8px);color:var(--si-foreground);}
#si-bts .si-bts-dp.vis{opacity:1;transform:translateX(0);background:rgba(59,130,246,0.05);}
#si-bts .si-bts-dp-dot{width:5px;height:5px;border-radius:50%;background:#cbd5e1;flex-shrink:0;}
#si-bts .si-bts-dp.vis .si-bts-dp-dot{background:var(--si-accent);}
#si-bts .si-bts-srcrow{display:flex;flex-wrap:wrap;gap:4px;margin-top:auto;padding-top:14px;}
#si-bts .si-bts-srctag{padding:3px 8px;border-radius:6px;background:rgba(0,0,0,0.03);font-size:10px;color:var(--si-muted-foreground);}

#si-bts .si-bts-final{display:flex;flex-direction:column;align-items:center;justify-content:center;flex:1;text-align:center;}
#si-bts .si-bts-final-check{width:54px;height:54px;border-radius:50%;background:rgba(22,163,74,0.1);display:flex;align-items:center;justify-content:center;font-size:22px;color:var(--si-success);margin-bottom:15px;font-weight:700;}
#si-bts .si-bts-final-title{font-family:var(--si-font-heading);font-weight:800;font-size:17px;margin-bottom:5px;color:var(--si-foreground);}
#si-bts .si-bts-final-sub{font-size:13px;color:var(--si-muted-foreground);margin-bottom:18px;line-height:1.6;}
#si-bts .si-bts-bars{width:100%;max-width:300px;}
#si-bts .si-bts-bar-row{display:flex;justify-content:space-between;font-size:11px;margin-bottom:4px;font-weight:500;}
#si-bts .si-bts-bar-track{height:8px;border-radius:99px;overflow:hidden;margin-bottom:10px;}
#si-bts .si-bts-bar-track-red{background:rgba(220,38,38,0.1);}
#si-bts .si-bts-bar-track-blue{background:rgba(59,130,246,0.1);}
#si-bts .si-bts-bar-fill{height:100%;border-radius:99px;transition:width 1.2s ease;}

#si-bts .si-bts-strip{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-top:28px;}
#si-bts .si-bts-stat{text-align:center;padding:16px 8px;border-radius:14px;background:var(--si-glass-subtle-bg);border:1px solid var(--si-glass-border);backdrop-filter:blur(var(--si-glass-blur));-webkit-backdrop-filter:blur(var(--si-glass-blur));}
#si-bts .si-bts-stat-val{font-size:22px;font-weight:800;font-family:var(--si-font-heading);letter-spacing:-0.03em;color:var(--si-foreground);}
#si-bts .si-bts-stat-lbl{font-size:10.5px;color:var(--si-muted-foreground);margin-top:3px;}

#si-bts .si-bts-sources{text-align:center;margin-top:18px;padding:18px;border-radius:16px;background:rgba(59,130,246,0.025);}
#si-bts .si-bts-sources-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#94A3B8;margin-bottom:9px;}
#si-bts .si-bts-src{display:inline-block;padding:4px 9px;border-radius:7px;background:var(--si-card);border:1px solid var(--si-border);font-size:10.5px;color:var(--si-muted-foreground);margin:2px;}
#si-bts .si-bts-sources-note{font-size:11.5px;color:#94A3B8;margin-top:11px;font-style:italic;max-width:460px;margin-left:auto;margin-right:auto;line-height:1.5;}

@media(max-width:760px){
#si-bts .si-bts-grid{grid-template-columns:1fr;gap:12px;}
#si-bts .si-bts-steps{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
#si-bts .si-bts-panel{min-height:340px;padding:18px;}
#si-bts .si-bts-strip{grid-template-columns:repeat(3,1fr);}
}
@media(max-width:420px){
#si-bts .si-bts-steps{grid-template-columns:1fr;}
#si-bts .si-bts-vs{grid-template-columns:1fr;}
}
@media(prefers-reduced-motion:reduce){
#si-bts .si-bts-pipe{transition:none;}
#si-bts .si-bts-dp{transition:none;}
#si-bts .si-bts-bar-fill{transition:none;}
}
</style>

</section>
