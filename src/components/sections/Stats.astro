---
<!-- ScoreImmo - Chiffres clés -->
<section class="si-section" aria-label="ScoreImmo en chiffres">
  <div class="si-container">
    <h2 class="si-section-title si-reveal" style="margin-bottom:3rem;">ScoreImmo en chiffres</h2>

    <div class="si-grid-4">
      <!-- Stat 1 -->
      <div class="si-card si-glass-subtle si-reveal si-reveal-stagger" style="border-radius:var(--si-radius-2xl);">
        <div class="si-stat">
          <div class="si-stat-number si-counter" data-target="9" data-suffix="">9</div>
          <div class="si-stat-label">sources de donn&eacute;es simultan&eacute;es</div>
        </div>
      </div>

      <!-- Stat 2 -->
      <div class="si-card si-glass-subtle si-reveal si-reveal-stagger" style="border-radius:var(--si-radius-2xl);">
        <div class="si-stat">
          <div class="si-stat-number si-counter" data-target="13" data-suffix="">13</div>
          <div class="si-stat-label">sections dans le rapport</div>
        </div>
      </div>

      <!-- Stat 3 -->
      <div class="si-card si-glass-subtle si-reveal si-reveal-stagger" style="border-radius:var(--si-radius-2xl);">
        <div class="si-stat">
          <div class="si-stat-number si-counter" data-target="250" data-suffix="+">250+</div>
          <div class="si-stat-label">v&eacute;rifications automatiques</div>
        </div>
      </div>

      <!-- Stat 4 -->
      <div class="si-card si-glass-subtle si-reveal si-reveal-stagger" style="border-radius:var(--si-radius-2xl);">
        <div class="si-stat">
          <div class="si-stat-number si-counter" data-target="30" data-suffix="s">30s</div>
          <div class="si-stat-label">de g&eacute;n&eacute;ration</div>
        </div>
      </div>
    </div>
  </div>
</section>
