---
// Hero aligne sur l'app (refonte 2026-06-03) : "Analysez une annonce" + mot
// rotatif accent (comme RotatingHero de l'app), placeholders rotatifs dans le
// champ, layout mobile-first (input full-width + bouton empile, comme l'app).
// DA preservee (bleu #3B82F6, Inter/DM Sans). Aucun token modifie.
---
<section class="si-section si-hero" aria-label="ScoreImmo : analysez une annonce immobilière en 30 secondes">
  <div class="si-container">
    <div class="si-hero-inner">

      <!-- Badge trust -->
      <div class="si-reveal" style="margin-bottom:1.4rem;">
        <span class="si-badge si-badge-hero"><span class="si-badge-dot" aria-hidden="true"></span>Données publiques · 9 sources officielles · 100% indépendant</span>
      </div>

      <!-- Titre : prefixe + mot rotatif accent (signature app) -->
      <h1 class="si-hero-rot si-reveal si-reveal-delay-1">
        <span class="si-hero-prefix">Analysez une annonce</span>
        <span class="si-hero-word-wrap"><span class="si-hero-word" id="si-hero-word">d'appartement</span></span>
      </h1>

      <!-- Subtitle (copie app) -->
      <p class="si-hero-subtitle si-reveal si-reveal-delay-2" style="max-width:34rem;margin-left:auto;margin-right:auto;">
        Collez le lien d'une annonce, obtenez un rapport complet en 30 secondes.
      </p>

      <!-- Social proof + compteur anime -->
      <div class="si-hero-social-proof si-reveal si-reveal-delay-2" style="margin-top:1rem;">
        <div class="si-proof-avatars">
          <span class="si-avatar" style="background:#3B82F6;"></span>
          <span class="si-avatar" style="background:#EF4444;"></span>
          <span class="si-avatar" style="background:#22C55E;"></span>
          <span class="si-avatar" style="background:#F59E0B;"></span>
          <span class="si-avatar" style="background:#A855F7;"></span>
        </div>
        <span class="si-proof-text"><strong class="si-proof-count">0</strong> annonces analysées ce mois</span>
      </div>

      <!-- Champ URL : input full-width + bouton (empile sur mobile comme l'app) -->
      <form class="si-url-form si-reveal si-reveal-delay-3" id="si-url-form" action="https://app.score-immo.fr/app" method="get" novalidate>
        <div class="si-url-row">
          <div class="si-url-box">
            <svg class="si-url-icon" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/>
            </svg>
            <div class="si-url-field">
              <input
                type="url"
                name="url"
                id="si-url-input"
                class="si-url-input"
                placeholder="Collez un lien d'annonce"
                autocomplete="off"
                spellcheck="false"
                inputmode="url"
                aria-label="URL de l'annonce à analyser"
              />
              <span class="si-rotor" id="si-rotor" aria-hidden="true"><span class="si-rotor-text" id="si-rotor-text">Collez un lien LeBonCoin...</span></span>
            </div>
          </div>
          <button type="submit" class="si-btn si-btn-primary si-url-submit">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true" style="margin-right:8px;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m1.85-5.4a7.25 7.25 0 11-14.5 0 7.25 7.25 0 0114.5 0z"/>
            </svg>
            Analyser
          </button>
        </div>
        <p class="si-url-hint" id="si-url-hint">Ou <a href="https://app.score-immo.fr/app?utm_source=site&utm_medium=hero">ouvrez l'outil directement</a> pour utiliser un exemple.</p>
      </form>

      <!-- Reassurance (app-like) -->
      <p class="si-hero-reassurance si-reveal si-reveal-delay-4" style="margin-top:0.95rem;font-size:0.875rem;color:var(--si-muted-foreground);">
        Gratuit · Sans engagement · 1ère analyse offerte
      </p>

      <!-- Portals marquee -->
      <div class="si-portals-marquee si-reveal si-reveal-delay-4" style="margin-top:2rem;">
        <p style="font-size:0.875rem;color:#6b7280;margin-bottom:0.5rem;">Compatible avec toutes les annonces des grands portails</p>
        <div class="si-portals-track-wrap">
