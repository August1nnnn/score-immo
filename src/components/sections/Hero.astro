<script>
(function(){
  // --- Compteur dynamique ---
  var el = document.querySelector('.si-proof-count');
  if (el) {
    var now = new Date();
    var day = now.getDate();
    var hour = now.getHours();
    var daysInMonth = new Date(now.getFullYear(), now.getMonth() + 1, 0).getDate();
    var seed = now.getFullYear() * 12 + now.getMonth();
    var objectif = 3500 + (seed * 7 + 13) % 700;
    var progression = ((day - 1) * 24 + hour) / (daysInMonth * 24);
    var target = Math.floor(progression * objectif);
    target += Math.floor(Math.random() * 80 - 40);
    if (target < 0) target = 0;
    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var fmt = function(n) { return new Intl.NumberFormat('fr-FR').format(Math.floor(n)); };
    if (reduced) {
      el.textContent = fmt(target);
    } else {
      el.textContent = '0';
      var start = null, duration = 1500;
      function step(ts) {
        if (!start) start = ts;
        var p = Math.min((ts - start) / duration, 1);
        var ease = 1 - Math.pow(1 - p, 3);
        el.textContent = fmt(ease * target);
        if (p < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }
  }

  var form = document.getElementById('si-url-form');
  var input = document.getElementById('si-url-input');
  var hint = document.getElementById('si-url-hint');
  var field = input ? input.parentNode : null;
  if (!form || !input) return;

  // --- Placeholder rotatif (overlay, masque quand focus/saisie) ---
  var rotor = document.getElementById('si-rotor');
  var rotorText = document.getElementById('si-rotor-text');
  var isNarrow = window.matchMedia('(max-width: 640px)').matches;
  var PHRASES = isNarrow ? [
    "Colle un lien, on analyse",
    "Ce prix est-il justifié ?",
    "SeLoger, LBC, PAP...",
    "Vérifie avant d'acheter",
    "Prix, DPE, risques en 30s"
  ] : [
    "Colle un lien, vois ce que vaut vraiment l'annonce",
    "Ton T3 à 250 000 €, au bon prix ?",
    "SeLoger, LeBonCoin, PAP... colle l'annonce",
    "Avant de faire une offre, vérifie le prix",
    "Prix, DPE, risques, quartier en 30 secondes"
  ];
  if (rotorText) rotorText.textContent = PHRASES[0];
  var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var rotorIdx = 0, rotorTimer = null;
  function rotorTick() {
    if (!rotorText) return;
    rotorText.classList.add('out');
    setTimeout(function(){
      rotorIdx = (rotorIdx + 1) % PHRASES.length;
      rotorText.textContent = PHRASES[rotorIdx];
      rotorText.classList.remove('out');
    }, 380);
  }
  function startRotor(){ if (rotorTimer || reducedMotion) return; rotorTimer = setInterval(rotorTick, 3000); }
  function stopRotor(){ if (rotorTimer) { clearInterval(rotorTimer); rotorTimer = null; } }
  function syncRotor(){
    // visible seulement si vide ET non focus
    var show = !input.value && document.activeElement !== input;
    if (rotor) rotor.classList.toggle('hidden', !show);
    if (show) startRotor(); else stopRotor();
  }
  input.addEventListener('focus', function(){ if (field) field.classList.add('typing'); syncRotor(); });
  input.addEventListener('blur', function(){ if (field && !input.value) field.classList.remove('typing'); syncRotor(); });
  syncRotor();

  // --- Validation + UTM ---
  var portalsRegex = /(leboncoin\.fr|seloger\.com|bienici\.com|pap\.fr|logic-immo\.com|century21\.fr|orpi\.com|laforet\.com|ouestfrance-immo\.com|paruvendu\.fr|meilleursagents\.com|immobilier\.lefigaro\.fr|bellesdemeures\.com|barnes-international\.com|superimmo\.com|green-acres\.fr|stephaneplazaimmobilier\.com|guy-hoquet\.com|immoneuf\.com|zefir\.fr)/i;

  form.addEventListener('submit', function(e) {
    var val = (input.value || '').trim();
    if (!val) return;
    if (!/^https?:\/\//i.test(val)) {
      input.value = 'https://' + val;
      val = input.value;
    }
    try {
      var u = new URL(val);
      if (!portalsRegex.test(u.hostname)) {
        e.preventDefault();
        hint.innerHTML = "Portail non reconnu. Essaie SeLoger, LeBonCoin, Bien'ici, PAP... ou <a href='https://app.score-immo.fr/app?utm_source=site&utm_medium=hero'>ouvre l'outil directement</a>.";
        hint.style.color = 'var(--si-destructive, #DC2626)';
        input.focus();
        return;
      }
    } catch (err) {
      e.preventDefault();
      hint.innerHTML = "URL invalide. Colle le lien complet de l'annonce.";
      hint.style.color = 'var(--si-destructive, #DC2626)';
      input.focus();
      return;
    }
    var action = new URL(form.action);
    action.searchParams.set('utm_source', 'site');
    action.searchParams.set('utm_medium', 'hero_url_input');
    action.searchParams.set('utm_campaign', 'hero_instant_analyze');
    form.action = action.toString();
  });

  input.addEventListener('input', function() {
    hint.style.color = '';
    hint.innerHTML = "Ou <a href='https://app.score-immo.fr/app?utm_source=site&utm_medium=hero'>ouvre l'outil directement</a> pour utiliser un exemple.";
    syncRotor();
  });
})();
</script>

<style>
  /* ===== Hero alive ===== */
  .si-hero {
    position: relative;
    padding-top: 2rem;
    padding-bottom: 1rem;
    overflow: hidden;
  }
  .si-hero-inner {
    max-width: 52rem;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 2;
  }
  .si-hero-title {
    font-size: clamp(2.1rem, 5.6vw, 3.5rem);
    line-height: 1.06;
    letter-spacing: -0.02em;
  }

  /* ===== Aurora animee ===== */
  .si-hero-aurora {
    position: absolute;
    left: 50%;
    top: -120px;
    transform: translateX(-50%);
    width: min(1100px, 140%);
    height: 620px;
    z-index: 0;
    pointer-events: none;
    filter: blur(56px);
    opacity: 0.85;
  }
  .si-hero-aurora span {
    position: absolute;
    display: block;
    border-radius: 50%;
    will-change: transform;
  }
  .si-aurora-1 { width: 460px; height: 460px; left: 4%;  top: 30px;  background: radial-gradient(circle, rgba(59,130,246,0.50), transparent 68%); animation: si-aur1 22s ease-in-out infinite; }
  .si-aurora-2 { width: 420px; height: 420px; right: 2%;  top: 0;     background: radial-gradient(circle, rgba(129,140,248,0.42), transparent 68%); animation: si-aur2 26s ease-in-out infinite; }
  .si-aurora-3 { width: 380px; height: 380px; left: 32%; top: 150px; background: radial-gradient(circle, rgba(147,197,253,0.45), transparent 70%); animation: si-aur3 19s ease-in-out infinite; }
  .si-aurora-4 { width: 340px; height: 340px; right: 24%; top: 80px;  background: radial-gradient(circle, rgba(196,181,253,0.34), transparent 70%); animation: si-aur4 24s ease-in-out infinite; }
  @keyframes si-aur1 { 0%,100%{transform:translate(0,0) scale(1);} 50%{transform:translate(60px,40px) scale(1.12);} }
  @keyframes si-aur2 { 0%,100%{transform:translate(0,0) scale(1);} 50%{transform:translate(-50px,50px) scale(1.1);} }
  @keyframes si-aur3 { 0%,100%{transform:translate(0,0) scale(1);} 50%{transform:translate(40px,-40px) scale(1.15);} }
  @keyframes si-aur4 { 0%,100%{transform:translate(0,0) scale(1);} 50%{transform:translate(-40px,30px) scale(1.08);} }

  /* ===== Chips flottantes (desktop) ===== */
  .si-hero-chips { position: absolute; inset: 0; z-index: 1; pointer-events: none; display: none; }
  .si-chip {
    position: absolute;
    font-family: var(--si-font-body);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--si-accent);
    padding: 7px 13px;
    border-radius: 99px;
    background: var(--si-glass-bg-elevated);
    border: 1px solid var(--si-glass-border);
    box-shadow: var(--si-glass-shadow);
    backdrop-filter: blur(var(--si-glass-blur));
    -webkit-backdrop-filter: blur(var(--si-glass-blur));
    white-space: nowrap;
  }
  .si-chip-a { left: 5%;  top: 120px; animation: si-float 7s ease-in-out infinite; }
  .si-chip-b { right: 7%; top: 90px;  animation: si-float 8.5s ease-in-out infinite 0.6s; }
  .si-chip-c { left: 9%;  top: 280px; animation: si-float 9s ease-in-out infinite 0.3s; }
  .si-chip-d { right: 6%; top: 320px; animation: si-float 7.8s ease-in-out infinite 0.9s; }
  @keyframes si-float { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-12px);} }
  @media (min-width: 1080px) { .si-hero-chips { display: block; } }

  /* ===== Badge ===== */
  .si-badge-hero {
    backdrop-filter: blur(var(--si-glass-blur));
    -webkit-backdrop-filter: blur(var(--si-glass-blur));
    box-shadow: var(--si-shadow-sm);
  }
  .si-badge-dot {
    display: inline-block;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--si-accent);
    margin-right: 7px;
    vertical-align: middle;
    box-shadow: 0 0 0 3px rgba(59,130,246,0.18);
    animation: si-hero-dot 2.4s ease infinite;
  }
  @keyframes si-hero-dot {
    0%,100% { box-shadow: 0 0 0 3px rgba(59,130,246,0.18); }
    50% { box-shadow: 0 0 0 5px rgba(59,130,246,0.06); }
  }

  /* ===== H1 highlight + sheen ===== */
  .si-hero-accent {
    position: relative;
    background: linear-gradient(transparent 60%, rgba(59,130,246,0.22) 0);
    padding: 0 4px;
    border-radius: 3px;
    white-space: nowrap;
  }
  .si-hero-accent::after {
    content: "";
    position: absolute;
    left: 0; top: 0; bottom: 0; width: 40%;
    background: linear-gradient(100deg, transparent, rgba(255,255,255,0.65), transparent);
    transform: skewX(-18deg);
    animation: si-sheen 4.5s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes si-sheen {
    0%, 60% { left: -45%; }
    100% { left: 115%; }
  }

  /* ===== Search bar : anneau shimmer + glow focus ===== */
  .si-url-form { max-width: 38rem; margin: 2rem auto 0; }
  .si-url-ring {
    position: relative;
    padding: 2.5px;
    border-radius: 17px;
    background: linear-gradient(90deg, #3B82F6, #60A5FA, #818CF8, #93C5FD, #60A5FA, #3B82F6);
    background-size: 300% 100%;
    animation: si-ring 6s linear infinite;
    box-shadow: 0 10px 34px rgba(59,130,246,0.14);
    transition: box-shadow 0.3s ease, transform 0.2s ease;
  }
  @keyframes si-ring { 0% { background-position: 0% 50%; } 100% { background-position: 300% 50%; } }
  .si-url-ring:focus-within {
    box-shadow: 0 14px 44px rgba(59,130,246,0.30), 0 0 0 5px rgba(59,130,246,0.12);
    animation-duration: 2.4s;
  }
  .si-url-input-wrap {
    display: flex;
    align-items: center;
    gap: 0;
    background: #fff;
    border-radius: 15px;
    padding: 6px 6px 6px 14px;
    transition: background 0.3s ease;
  }
  .si-url-ring:focus-within .si-url-input-wrap {
    background: linear-gradient(180deg, rgba(59,130,246,0.05), rgba(59,130,246,0.015));
  }
  .si-url-icon { flex-shrink: 0; color: var(--si-muted-foreground); margin-right: 10px; transition: color 0.25s ease; }
  .si-url-ring:focus-within .si-url-icon { color: var(--si-accent); }

  .si-url-field { position: relative; flex: 1; min-width: 0; display: flex; align-items: center; }
  .si-url-input {
    flex: 1;
    min-width: 0;
    border: none;
    outline: none;
    background: transparent;
    font-family: var(--si-font-body);
    font-size: 1rem;
    color: var(--si-foreground);
    padding: 13px 0;
