</section>

<script>
(function(){
  var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // --- Compteur dynamique ---
  var el = document.querySelector('.si-proof-count');
  if (el) {
    var now = new Date();
    var day = now.getDate(), hour = now.getHours();
    var daysInMonth = new Date(now.getFullYear(), now.getMonth() + 1, 0).getDate();
    var seed = now.getFullYear() * 12 + now.getMonth();
    var objectif = 3500 + (seed * 7 + 13) % 700;
    var progression = ((day - 1) * 24 + hour) / (daysInMonth * 24);
    var target = Math.floor(progression * objectif) + Math.floor(Math.random() * 80 - 40);
    if (target < 0) target = 0;
    var fmt = function(n) { return new Intl.NumberFormat('fr-FR').format(Math.floor(n)); };
    if (reduced) { el.textContent = fmt(target); }
    else {
      el.textContent = '0';
      var s0 = null, dur = 1500;
      (function stepc(ts){ if(!s0)s0=ts; var p=Math.min((ts-s0)/dur,1); el.textContent=fmt((1-Math.pow(1-p,3))*target); if(p<1)requestAnimationFrame(stepc); })(performance.now());
    }
  }

  // --- Mot rotatif du titre (signature app) ---
  var word = document.getElementById('si-hero-word');
  var WORDS = ["d'appartement","de maison","de terrain","de duplex","de loft","de château","d'immeuble","de domaine","de parking","de studio","de villa","de ferme","d'entrepôt"];
  if (word && !reduced) {
    var wi = 0;
    setInterval(function(){
      word.classList.add('out');
      setTimeout(function(){
        wi = (wi + 1) % WORDS.length;
        word.textContent = WORDS[wi];
        word.classList.remove('out');
        word.classList.add('in');
        requestAnimationFrame(function(){ requestAnimationFrame(function(){ word.classList.remove('in'); }); });
      }, 250);
    }, 2500);
  }

  var form = document.getElementById('si-url-form');
  var input = document.getElementById('si-url-input');
  var hint = document.getElementById('si-url-hint');
  var field = input ? input.parentNode : null;
  if (!form || !input) return;

  // --- Placeholder rotatif (style app : "Collez un lien X...") ---
  var rotor = document.getElementById('si-rotor');
  var rotorText = document.getElementById('si-rotor-text');
  var PH = ["Collez un lien LeBonCoin...","Collez un lien SeLoger...","Collez un lien Bien'ici...","Collez un lien PAP...","Collez un lien Logic-Immo...","Collez un lien Orpi..."];
  var pi = 0, ptimer = null;
  function ptick(){ if(!rotorText) return; rotorText.classList.add('out'); setTimeout(function(){ pi=(pi+1)%PH.length; rotorText.textContent=PH[pi]; rotorText.classList.remove('out'); }, 360); }
  function pstart(){ if(ptimer||reduced) return; ptimer=setInterval(ptick, 2800); }
  function pstop(){ if(ptimer){ clearInterval(ptimer); ptimer=null; } }
  function psync(){ var show = !input.value && document.activeElement !== input; if(rotor) rotor.classList.toggle('hidden', !show); if(show) pstart(); else pstop(); }
  input.addEventListener('focus', function(){ if(field) field.classList.add('typing'); psync(); });
  input.addEventListener('blur', function(){ if(field && !input.value) field.classList.remove('typing'); psync(); });
  psync();

  // --- Validation + UTM ---
  var portalsRegex = /(leboncoin\.fr|seloger\.com|bienici\.com|pap\.fr|logic-immo\.com|century21\.fr|orpi\.com|laforet\.com|ouestfrance-immo\.com|paruvendu\.fr|meilleursagents\.com|immobilier\.lefigaro\.fr|bellesdemeures\.com|barnes-international\.com|superimmo\.com|green-acres\.fr|stephaneplazaimmobilier\.com|guy-hoquet\.com|immoneuf\.com|zefir\.fr)/i;
  form.addEventListener('submit', function(e) {
    var val = (input.value || '').trim();
    if (!val) return;
    if (!/^https?:\/\//i.test(val)) { input.value = 'https://' + val; val = input.value; }
    try {
      var u = new URL(val);
      if (!portalsRegex.test(u.hostname)) {
        e.preventDefault();
        hint.innerHTML = "Portail non reconnu. Essaie SeLoger, LeBonCoin, Bien'ici, PAP... ou <a href='https://app.score-immo.fr/app?utm_source=site&utm_medium=hero'>ouvre l'outil directement</a>.";
        hint.style.color = 'var(--si-destructive, #DC2626)'; input.focus(); return;
      }
    } catch (err) {
      e.preventDefault();
      hint.innerHTML = "URL invalide. Colle le lien complet de l'annonce.";
      hint.style.color = 'var(--si-destructive, #DC2626)'; input.focus(); return;
    }
    var action = new URL(form.action);
    action.searchParams.set('utm_source', 'site');
    action.searchParams.set('utm_medium', 'hero_url_input');
    action.searchParams.set('utm_campaign', 'hero_instant_analyze');
    form.action = action.toString();
  });
  input.addEventListener('input', function() {
    hint.style.color = '';
    hint.innerHTML = "Ou <a href='https://app.score-immo.fr/app?utm_source=site&utm_medium=hero'>ouvrez l'outil directement</a> pour utiliser un exemple.";
    psync();
  });
})();
</script>

<style>
  .si-hero { position: relative; padding-top: 2.2rem; padding-bottom: 1rem; overflow: hidden; }
  .si-hero-inner { max-width: 46rem; margin: 0 auto; text-align: center; position: relative; z-index: 1; }

  /* ===== Badge ===== */
  .si-badge-hero { backdrop-filter: blur(var(--si-glass-blur)); -webkit-backdrop-filter: blur(var(--si-glass-blur)); box-shadow: var(--si-shadow-sm); }
  .si-badge-dot { display:inline-block; width:6px; height:6px; border-radius:50%; background:var(--si-accent); margin-right:7px; vertical-align:middle; box-shadow:0 0 0 3px rgba(59,130,246,0.18); animation:si-hero-dot 2.4s ease infinite; }
  @keyframes si-hero-dot { 0%,100%{box-shadow:0 0 0 3px rgba(59,130,246,0.18);} 50%{box-shadow:0 0 0 5px rgba(59,130,246,0.06);} }

  /* ===== Titre rotatif (signature app) ===== */
  .si-hero-rot { margin: 0 0 0.6rem; }
  .si-hero-prefix {
    display: block;
    font-family: var(--si-font-heading);
    font-weight: 700;
    color: var(--si-foreground);
    font-size: clamp(1.4rem, 3.4vw, 2rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
  }
  .si-hero-word-wrap {
    position: relative;
    display: block;
    height: clamp(2.8rem, 8.5vw, 4.4rem);
    overflow: hidden;
    margin-top: 0.15rem;
  }
  .si-hero-word {
    position: absolute;
    left: 0; right: 0; top: 0;
    font-family: var(--si-font-heading);
    font-weight: 800;
    color: var(--si-accent);
    font-size: clamp(2.2rem, 6.6vw, 3.6rem);
    line-height: 1.15;
    letter-spacing: -0.03em;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .si-hero-word.out { opacity: 0; transform: translateY(-22px); }
  .si-hero-word.in { opacity: 0; transform: translateY(22px); transition: none; }

  /* ===== Search : input full-width + bouton (stack mobile comme l'app) ===== */
  .si-url-form { max-width: 38rem; margin: 1.6rem auto 0; }
  .si-url-row { display: flex; gap: 8px; align-items: stretch; }
  .si-url-box {
    flex: 1; min-width: 0;
    display: flex; align-items: center;
    background: #fff;
    border: 1.5px solid var(--si-border);
    border-radius: 14px;
    padding: 6px 6px 6px 14px;
    box-shadow: 0 8px 28px rgba(0,0,0,0.05);
    transition: border-color 0.22s ease, box-shadow 0.22s ease, background 0.22s ease;
  }
  .si-url-box:focus-within {
    border-color: var(--si-accent);
    background: linear-gradient(180deg, rgba(59,130,246,0.05), rgba(59,130,246,0.012));
    box-shadow: 0 12px 40px rgba(59,130,246,0.20), 0 0 0 4px rgba(59,130,246,0.12);
  }
  .si-url-icon { flex-shrink: 0; color: var(--si-muted-foreground); margin-right: 10px; transition: color 0.22s ease; }
  .si-url-box:focus-within .si-url-icon { color: var(--si-accent); }
  .si-url-field { position: relative; flex: 1; min-width: 0; display: flex; align-items: center; }
  .si-url-input { flex: 1; min-width: 0; border: none; outline: none; background: transparent; font-family: var(--si-font-body); font-size: 1rem; color: var(--si-foreground); padding: 13px 0; }
  .si-url-input::placeholder { color: var(--si-muted-foreground); opacity: 0; transition: opacity 0.2s ease; }
  .si-url-field.typing .si-url-input::placeholder { opacity: 1; }
  .si-rotor { position: absolute; left: 0; right: 0; top: 0; bottom: 0; display: flex; align-items: center; pointer-events: none; overflow: hidden; }
  .si-rotor.hidden { opacity: 0; }
  .si-rotor-text { display: block; max-width: 100%; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--si-muted-foreground); font-size: 1rem; transition: opacity 0.34s ease, transform 0.34s ease; }
  .si-rotor-text.out { opacity: 0; transform: translateY(-8px); }
  .si-url-submit { flex-shrink: 0; display: inline-flex; align-items: center; justify-content: center; padding: 0 26px; border-radius: 12px; font-size: 0.95rem; white-space: nowrap; transition: transform 0.18s ease, box-shadow 0.18s ease; }
  .si-url-submit:hover { transform: translateY(-1px); }
  .si-url-hint { font-size: 0.8125rem; color: var(--si-muted-foreground); margin: 0.7rem 0 0; }
  .si-url-hint a { color: var(--si-accent); text-decoration: underline; }

  @media (max-width: 640px) {
    .si-url-row { flex-direction: column; gap: 10px; }
    .si-url-submit { width: 100%; padding: 13px; height: auto; }
    .si-url-input { font-size: 16px; padding: 12px 0; }
    .si-rotor-text { font-size: 0.95rem; }
  }

  /* ===== Portals marquee ===== */
  .si-portals-marquee { text-align: center; }
  .si-portals-track-wrap { overflow: hidden; -webkit-mask-image: linear-gradient(90deg, transparent, black 10%, black 90%, transparent); mask-image: linear-gradient(90deg, transparent, black 10%, black 90%, transparent); height: 36px; display: flex; align-items: center; }
  .si-portals-track { display: flex; gap: 0.75rem; white-space: nowrap; animation: si-portals-scroll 60s linear infinite; width: max-content; }
  .si-portals-track-wrap:hover .si-portals-track { animation-play-state: paused; }
  .si-portal-logo { font-family: var(--si-font-heading); font-weight: 600; font-size: 0.875rem; opacity: 0.75; transition: all 0.2s ease; cursor: pointer; text-decoration: none; }
  .si-portal-logo:hover { opacity: 1; transform: scale(1.08); filter: brightness(1.05); }
  .si-portal-dot { color: var(--si-muted-foreground); opacity: 0.4; }
  @keyframes si-portals-scroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
  @media (max-width: 767px) { .si-portals-track-wrap { height: 28px; } .si-portal-logo { font-size: 0.75rem; } .si-portals-track { animation-duration: 45s; } }

  @media (prefers-reduced-motion: reduce) {
    .si-badge-dot, .si-portals-track, .si-hero-word { animation: none !important; }
  }
</style>
