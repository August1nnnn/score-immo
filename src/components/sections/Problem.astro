---
---
<!-- ScoreImmo - Le Probl&egrave;me (multi-persona avec pills) -->
<section class="si-section" aria-label="Pourquoi ScoreImmo" style="padding-top:2.5rem;">
  <div class="si-container" style="max-width:48rem;">
    <h2 class="si-section-title si-reveal">Un march&eacute; o&ugrave; tout le monde avance &agrave; l'aveugle</h2>
    <p class="si-section-subtitle si-reveal" style="margin-top:0.5rem;">Que tu ach&egrave;tes, que tu vendes ou que tu accompagnes un client, le probl&egrave;me est le m&ecirc;me : pas assez de donn&eacute;es objectives.</p>

    <!-- Pills -->
    <div class="si-reveal si-reveal-delay-1" style="display:flex;justify-content:center;gap:0.5rem;margin-top:2rem;flex-wrap:wrap;">
      <button class="si-problem-pill si-problem-pill-active" data-tab="acheteur" onclick="switchProblemTab('acheteur')" style="cursor:pointer;">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" style="vertical-align:middle;margin-right:0.375rem;"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0"/></svg>Acheteur
      </button>
      <button class="si-problem-pill" data-tab="vendeur" onclick="switchProblemTab('vendeur')" style="cursor:pointer;">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" style="vertical-align:middle;margin-right:0.375rem;"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21"/></svg>Vendeur
      </button>
      <button class="si-problem-pill" data-tab="agent" onclick="switchProblemTab('agent')" style="cursor:pointer;">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" style="vertical-align:middle;margin-right:0.375rem;"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z"/></svg>Agent immobilier
      </button>
    </div>

    <!-- Tab content -->
    <div style="margin-top:1.5rem;">

      <!-- Acheteur -->
      <div class="si-problem-tab si-problem-tab-active" id="tab-acheteur">
        <div style="display:flex;flex-direction:column;gap:1.25rem;">
          <div class="si-card si-glass-subtle" style="padding:1.5rem;border-radius:var(--si-radius-2xl);">
            <div style="display:flex;align-items:flex-start;gap:1rem;">
              <div class="si-icon-circle" style="background:rgba(220,38,38,0.1);">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#DC2626" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/></svg>
              </div>
              <div>
                <p style="font-family:var(--si-font-heading);font-weight:600;font-size:1rem;color:var(--si-foreground);margin-bottom:0.25rem;">20-25 ans de cr&eacute;dit. Des centaines de milliers d'euros.</p>
                <p style="font-size:0.875rem;color:var(--si-muted-foreground);line-height:1.625;">Une d&eacute;cision prise en 20 minutes de visite et sous pression de l'urgence. Sans donn&eacute;es, tu d&eacute;cides &agrave; l'aveugle.</p>
              </div>
            </div>
          </div>
          <div class="si-card si-glass-subtle" style="padding:1.5rem;border-radius:var(--si-radius-2xl);">
            <div style="display:flex;align-items:flex-start;gap:1rem;">
              <div class="si-icon-circle" style="background:rgba(245,158,11,0.1);">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#F59E0B" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z"/></svg>
              </div>
              <div>
                <p style="font-family:var(--si-font-heading);font-weight:600;font-size:1rem;color:var(--si-foreground);margin-bottom:0.25rem;">Le prix est-il juste ? Les risques ? Le quartier ?</p>
                <p style="font-size:0.875rem;color:var(--si-muted-foreground);line-height:1.625;">Le vendeur conna&icirc;t son bien, l'agent conna&icirc;t le march&eacute;. Toi, tu n'as que l'annonce. ScoreImmo te donne les m&ecirc;mes donn&eacute;es qu'eux.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Vendeur -->
      <div class="si-problem-tab" id="tab-vendeur" style="display:none;">
        <div style="display:flex;flex-direction:column;gap:1.25rem;">
          <div class="si-card si-glass-subtle" style="padding:1.5rem;border-radius:var(--si-radius-2xl);">
            <div style="display:flex;align-items:flex-start;gap:1rem;">
              <div class="si-icon-circle" style="background:rgba(220,38,38,0.1);">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#DC2626" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/></svg>
              </div>
              <div>
                <p style="font-family:var(--si-font-heading);font-weight:600;font-size:1rem;color:var(--si-foreground);margin-bottom:0.25rem;">Tu ne connais pas la vraie valeur de ton bien.</p>
                <p style="font-size:0.875rem;color:var(--si-muted-foreground);line-height:1.625;">Estim&eacute; trop haut, il ne se vend pas. Estim&eacute; trop bas, tu perds de l'argent. Les estimations en ligne sont vagues. Tu m&eacute;rites des chiffres pr&eacute;cis.</p>
              </div>
            </div>
          </div>
          <div class="si-card si-glass-subtle" style="padding:1.5rem;border-radius:var(--si-radius-2xl);">
            <div style="display:flex;align-items:flex-start;gap:1rem;">
              <div class="si-icon-circle" style="background:rgba(245,158,11,0.1);">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#F59E0B" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z"/></svg>
              </div>
              <div>
                <p style="font-family:var(--si-font-heading);font-weight:600;font-size:1rem;color:var(--si-foreground);margin-bottom:0.25rem;">Les acheteurs n&eacute;gocient. Tu n'as pas d'arguments.</p>
                <p style="font-size:0.875rem;color:var(--si-muted-foreground);line-height:1.625;">Avec un rapport ScoreImmo, tu montres les transactions r&eacute;elles du quartier, le DPE, l'&eacute;tat du march&eacute;. Des faits, pas des impressions. Ton prix est justifi&eacute;.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Agent -->
      <div class="si-problem-tab" id="tab-agent" style="display:none;">
        <div style="display:flex;flex-direction:column;gap:1.25rem;">
          <div class="si-card si-glass-subtle" style="padding:1.5rem;border-radius:var(--si-radius-2xl);">
            <div style="display:flex;align-items:flex-start;gap:1rem;">
              <div class="si-icon-circle" style="background:rgba(220,38,38,0.1);">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#DC2626" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/></svg>
              </div>
              <div>
                <p style="font-family:var(--si-font-heading);font-weight:600;font-size:1rem;color:var(--si-foreground);margin-bottom:0.25rem;">Tes clients h&eacute;sitent. Ils comparent. Ils doutent.</p>
                <p style="font-size:0.875rem;color:var(--si-muted-foreground);line-height:1.625;">Un acheteur qui doute du prix ne signe pas. Un vendeur mal inform&eacute; fixe un prix irr&eacute;aliste. Tu perds du temps &agrave; convaincre au lieu de closer.</p>
              </div>
            </div>
          </div>
          <div class="si-card si-glass-subtle" style="padding:1.5rem;border-radius:var(--si-radius-2xl);">
            <div style="display:flex;align-items:flex-start;gap:1rem;">
              <div class="si-icon-circle" style="background:rgba(245,158,11,0.1);">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#F59E0B" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z"/></svg>
              </div>
              <div>
                <p style="font-family:var(--si-font-heading);font-weight:600;font-size:1rem;color:var(--si-foreground);margin-bottom:0.25rem;">Le rapport fait le travail de conviction &agrave; ta place.</p>
                <p style="font-size:0.875rem;color:var(--si-muted-foreground);line-height:1.625;">Envoie un rapport ScoreImmo avant la visite. Ton client arrive inform&eacute;, rassur&eacute;, pr&ecirc;t &agrave; d&eacute;cider. Score bas ? Argument de n&eacute;go. Score haut ? Il signe.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Conclusion (always visible) -->
    <div class="si-card si-reveal si-reveal-delay-2" style="padding:1.5rem;border-radius:var(--si-radius-2xl);border:2px solid var(--si-accent);background:rgba(59,130,246,0.03);margin-top:1.5rem;">
      <div style="display:flex;align-items:flex-start;gap:1rem;">
        <div class="si-icon-circle">
          <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="var(--si-accent)" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
        </div>
        <div>
          <p style="font-family:var(--si-font-heading);font-weight:600;font-size:1rem;color:var(--si-foreground);margin-bottom:0.25rem;">Le rapport est le m&ecirc;me pour tous. Les chiffres ne trichent pas.</p>
          <p style="font-size:0.875rem;color:var(--si-muted-foreground);line-height:1.625;">230+ donn&eacute;es, 9 sources officielles, un score sur 100. Que tu ach&egrave;tes, que tu vendes ou que tu accompagnes un client : les m&ecirc;mes faits, la m&ecirc;me objectivit&eacute;. C'est &ccedil;a, ScoreImmo.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .si-problem-pill {
    display:inline-flex;align-items:center;
    padding:0.5rem 1rem;border-radius:9999px;
    font-size:0.875rem;font-weight:500;
    border:1.5px solid var(--si-border);
    background:var(--si-card);color:var(--si-muted-foreground);
    transition:all 0.2s ease;
    font-family:var(--si-font-body);
  }
  .si-problem-pill:hover {
    border-color:var(--si-accent);color:var(--si-accent);
  }
  .si-problem-pill-active {
    background:var(--si-accent) !important;
    color:#fff !important;
    border-color:var(--si-accent) !important;
  }
  .si-problem-pill-active svg { stroke:#fff; }
  .si-problem-tab { animation:si-fade-in 0.3s ease-out; }
  @keyframes si-fade-in { from{opacity:0;transform:translateY(8px);} to{opacity:1;transform:translateY(0);} }
</style>

<script>
function switchProblemTab(tab) {
  document.querySelectorAll('.si-problem-tab').forEach(function(el) { el.style.display = 'none'; el.classList.remove('si-problem-tab-active'); });
  document.querySelectorAll('.si-problem-pill').forEach(function(el) { el.classList.remove('si-problem-pill-active'); });
  var target = document.getElementById('tab-' + tab);
  if (target) { target.style.display = 'block'; target.classList.add('si-problem-tab-active'); }
  var pill = document.querySelector('[data-tab="' + tab + '"]');
  if (pill) { pill.classList.add('si-problem-pill-active'); }
}
</script>
