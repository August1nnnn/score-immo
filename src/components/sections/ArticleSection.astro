---
<!-- ScoreImmo - Article de blog stylé -->

<!-- Schema.org - Article + BreadcrumbList -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": ,
  "description": ,
  "datePublished": "",
  "dateModified": "",
  "author": { "@type": "Organization", "@id": "https://score-immo.fr/#organization" },
  "publisher": { "@type": "Organization", "@id": "https://score-immo.fr/#organization" },
  "mainEntityOfPage": { "@type": "WebPage", "@id": "https://score-immo.fr" },
  "image": ,
  "about": { "@type": "Thing", "name": "Immobilier en France" },
  "inLanguage": "fr-FR"
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://score-immo.fr" },
    { "@type": "ListItem", "position": 2, "name": "Le Guide de l'Acheteur", "item": "https://score-immo.fr/pages/guide" },
    { "@type": "ListItem", "position": 3, "name": , "item": "https://score-immo.fr" },
    { "@type": "ListItem", "position": 4, "name": , "item": "https://score-immo.fr" }
  ]
}
</script>

<article class="si-section">
  <div class="si-container" style="max-width:48rem;">
    <!-- Breadcrumb -->
    <nav style="margin-bottom:1.5rem;font-size:0.8125rem;color:var(--si-muted-foreground);font-family:var(--si-font-body);">
      <a href="/" style="color:var(--si-muted-foreground);text-decoration:none;">Accueil</a>
      <span style="margin:0 0.375rem;">/</span>
      <a href="/pages/guide" style="color:var(--si-muted-foreground);text-decoration:none;">Le Guide</a>
      <span style="margin:0 0.375rem;">/</span>
      <a href="" style="color:var(--si-muted-foreground);text-decoration:none;"></a>
      <span style="margin:0 0.375rem;">/</span>
      <span style="color:var(--si-foreground);"></span>
    </nav>

    <!-- Title -->
    <h1 style="font-family:var(--si-font-heading);font-weight:700;font-size:2rem;line-height:1.2;letter-spacing:-0.025em;color:var(--si-foreground);margin-bottom:1rem;">
      
    </h1>

    <!-- Meta -->
    <div style="display:flex;align-items:center;gap:1rem;margin-bottom:2rem;font-size:0.8125rem;color:var(--si-muted-foreground);font-family:var(--si-font-body);">
      <span></span>
      
        <span>&middot;</span>
        
          <span class="si-badge" style="font-size:0.6875rem;padding:0.125rem 0.5rem;"></span>
        
      
    </div>

    <!-- Featured image -->
    
      <div style="border-radius:var(--si-radius-2xl);overflow:hidden;margin-bottom:2rem;">
        <img
          src=""
          alt=""
          loading="lazy"
          style="width:100%;height:auto;display:block;"
        >
      </div>
    

    <!-- Content -->
    <div class="si-page-content" style="font-family:var(--si-font-body);color:var(--si-foreground);line-height:1.75;font-size:0.9375rem;">
      
    </div>

    <!-- CTA at the end of article -->
    <div style="margin-top:3rem;padding:2rem;background:rgba(59,130,246,0.03);border:1px solid rgba(59,130,246,0.15);border-radius:var(--si-radius-2xl);text-align:center;">
      <p style="font-family:var(--si-font-heading);font-weight:700;font-size:1.25rem;color:var(--si-foreground);margin-bottom:0.5rem;">
        Analysez un bien en 30 secondes
      </p>
      <p style="font-size:0.875rem;color:var(--si-muted-foreground);margin-bottom:1.25rem;">
        Collez le lien d'une annonce et obtenez un diagnostic complet.
      </p>
      <a href="https://app.score-immo.fr/app" class="si-btn si-btn-primary">
        Analyser une annonce
        <svg class="si-arrow" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-7-7 7 7-7 7"/></svg>
      </a>
    </div>

    <!-- Share / Navigation -->
    <div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid rgba(0,0,0,0.06);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;">
      
        <a href="" style="font-size:0.875rem;color:var(--si-accent);text-decoration:none;font-family:var(--si-font-body);">
          &larr; Article pr&eacute;c&eacute;dent
        </a>
      
        <span></span>
      
      
        <a href="" style="font-size:0.875rem;color:var(--si-accent);text-decoration:none;font-family:var(--si-font-body);">
          Article suivant &rarr;
        </a>
      
    </div>
  </div>
</article>

<style>
  .si-page-content h2 {
    font-family: var(--si-font-heading);
    font-weight: 700;
    font-size: 1.5rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--si-foreground);
  }
  .si-page-content h3 {
    font-family: var(--si-font-heading);
    font-weight: 600;
    font-size: 1.25rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .si-page-content p {
    margin-bottom: 1rem;
    color: var(--si-muted-foreground);
  }
  .si-page-content ul, .si-page-content ol {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    color: var(--si-muted-foreground);
  }
  .si-page-content li {
    margin-bottom: 0.375rem;
  }
  .si-page-content a {
    color: var(--si-accent);
    text-decoration: underline;
  }
  .si-page-content blockquote {
    border-left: 3px solid var(--si-accent);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--si-muted-foreground);
    font-style: italic;
  }
  .si-page-content img {
    border-radius: var(--si-radius);
    max-width: 100%;
    height: auto;
  }
  .si-page-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }
  .si-page-content th, .si-page-content td {
    padding: 0.75rem;
    border: 1px solid var(--si-border);
    font-size: 0.875rem;
  }
  .si-page-content th {
    background: var(--si-muted);
    font-weight: 600;
    text-align: left;
  }
</style>
