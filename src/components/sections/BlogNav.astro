---
---
<!-- ScoreImmo - Blog sub-navigation with breadcrumb -->
<div class="si-section" style="padding-top:1.5rem;padding-bottom:0;">
  <div class="si-container" style="max-width:48rem;">
    <!-- Breadcrumb -->
    <nav style="margin-bottom:1rem;font-size:0.8125rem;color:var(--si-muted-foreground);font-family:var(--si-font-body);">
      <a href="/" style="color:var(--si-muted-foreground);text-decoration:none;">Accueil</a>
      <span style="margin:0 0.375rem;">/</span>
      <a href="/pages/guide" style="color:var(--si-muted-foreground);text-decoration:none;">Le Guide</a>
      <span style="margin:0 0.375rem;">/</span>
      <span style="color:var(--si-foreground);"></span>
    </nav>

    <!-- Tab navigation -->
    <div class="si-guide-nav">
      <a href="/pages/guide" class="si-guide-nav-tab  si-guide-nav-tab-active">
        Tous les articles
      </a>
      <a href="/blogs/guides" class="si-guide-nav-tab si-guide-nav-tab-active">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/></svg>
        Guides
      </a>
      <a href="/blogs/villes" class="si-guide-nav-tab si-guide-nav-tab-active">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3 4.5h.008v.008H18v-.008zm0 3h.008v.008H18v-.008zm0 3h.008v.008H18v-.008z"/></svg>
        Villes
      </a>
      <a href="/blogs/quartiers" class="si-guide-nav-tab si-guide-nav-tab-active">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
        Quartiers
      </a>
    </div>
  </div>
</div>

<style>
  .si-guide-nav {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.25rem;
  }
  .si-guide-nav::-webkit-scrollbar {
    display: none;
  }
  .si-guide-nav-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1rem;
    border-radius: var(--si-radius);
    font-family: var(--si-font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s, color 0.15s;
    color: var(--si-muted-foreground);
    background: transparent;
    border: 1px solid var(--si-border);
  }
  .si-guide-nav-tab:hover {
    color: var(--si-foreground);
    border-color: var(--si-accent);
  }
  .si-guide-nav-tab-active {
    background: var(--si-accent);
    color: #fff;
    border-color: var(--si-accent);
  }
  .si-guide-nav-tab-active:hover {
    color: #fff;
  }
  .si-guide-nav-tab svg {
    flex-shrink: 0;
  }
</style>
