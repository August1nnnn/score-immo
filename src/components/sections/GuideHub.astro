---
---
<!-- ScoreImmo - Hub "Le Guide de l'Acheteur" -->
<section class="si-section" aria-label="Le Guide de l'Acheteur Immobilier">
  <div class="si-container">
    <!-- Hero -->
    <div style="text-align:center;margin-bottom:3rem;" class="si-reveal">
      <h1 class="si-section-title">Le Guide de l'Acheteur</h1>
      <p class="si-section-subtitle">Tout ce qu'il faut savoir avant d'acheter : guides pratiques, analyses par ville et quartiers recommand&eacute;s.</p>
    </div>

    <!-- 3 blog cards -->
    <div class="si-grid-3">

      <!-- Guides -->
      
      <div class="si-guide-card si-reveal">
        <div class="si-guide-card-header">
          <div class="si-guide-card-icon">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/></svg>
          </div>
          <div>
            <h2 class="si-guide-card-title">Guides pratiques</h2>
            <p class="si-guide-card-count"> articles</p>
          </div>
        </div>
        <p class="si-guide-card-desc">Conseils pratiques pour r&eacute;ussir votre achat : DPE, n&eacute;gociation, frais de notaire, financement.</p>

        
          <a href="" class="si-guide-article-link">
            
              <img src="" alt="" width="80" height="80" loading="lazy" class="si-guide-article-thumb">
            
              <div class="si-guide-article-thumb si-guide-article-thumb-placeholder">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" opacity="0.4"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/></svg>
              </div>
            
            <span class="si-guide-article-title"></span>
          </a>
        

        <a href="/blogs/guides" class="si-btn si-btn-secondary si-guide-card-cta">
          Voir les guides
          <svg class="si-arrow" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-7-7 7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Villes -->
      
      <div class="si-guide-card si-reveal">
        <div class="si-guide-card-header">
          <div class="si-guide-card-icon">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3 4.5h.008v.008H18v-.008zm0 3h.008v.008H18v-.008zm0 3h.008v.008H18v-.008z"/></svg>
          </div>
          <div>
            <h2 class="si-guide-card-title">Analyses par ville</h2>
            <p class="si-guide-card-count"> articles</p>
          </div>
        </div>
        <p class="si-guide-card-desc">Analyses du march&eacute; immobilier ville par ville : prix, tendances, quartiers, potentiel.</p>

        
          <a href="" class="si-guide-article-link">
            
              <img src="" alt="" width="80" height="80" loading="lazy" class="si-guide-article-thumb">
            
              <div class="si-guide-article-thumb si-guide-article-thumb-placeholder">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" opacity="0.4"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3 4.5h.008v.008H18v-.008zm0 3h.008v.008H18v-.008zm0 3h.008v.008H18v-.008z"/></svg>
              </div>
            
            <span class="si-guide-article-title"></span>
          </a>
        

        
          <p class="si-guide-card-empty">Les analyses arrivent bient&ocirc;t !</p>
        

        <a href="/blogs/villes" class="si-btn si-btn-secondary si-guide-card-cta">
          Voir les villes
          <svg class="si-arrow" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-7-7 7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Quartiers -->
      
      <div class="si-guide-card si-reveal">
        <div class="si-guide-card-header">
          <div class="si-guide-card-icon">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
          </div>
          <div>
            <h2 class="si-guide-card-title">Quartiers recommand&eacute;s</h2>
            <p class="si-guide-card-count"> articles</p>
          </div>
        </div>
        <p class="si-guide-card-desc">Les meilleurs quartiers pour investir ou habiter dans chaque grande ville de France.</p>

        
          <a href="" class="si-guide-article-link">
            
              <img src="" alt="" width="80" height="80" loading="lazy" class="si-guide-article-thumb">
            
              <div class="si-guide-article-thumb si-guide-article-thumb-placeholder">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" opacity="0.4"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
              </div>
            
            <span class="si-guide-article-title"></span>
          </a>
        

        
          <p class="si-guide-card-empty">Les analyses arrivent bient&ocirc;t !</p>
        

        <a href="/blogs/quartiers" class="si-btn si-btn-secondary si-guide-card-cta">
          Voir les quartiers
          <svg class="si-arrow" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-7-7 7 7-7 7"/></svg>
        </a>
      </div>

    </div>

    <!-- Outils gratuits -->
    <div style="margin-top:3rem;" class="si-reveal">
      <div style="text-align:center;margin-bottom:2rem;">
        <h2 class="si-section-title" style="font-size:1.5rem;">Outils gratuits</h2>
        <p class="si-section-subtitle" style="font-size:0.9375rem;">Simule tes frais, ton budget et ta rentabilit&eacute; en quelques clics.</p>
      </div>
      <div class="si-grid-2x2">
        <a href="/pages/calculateur-frais-de-notaire" class="si-tool-card">
          <div class="si-tool-card-icon">
            <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <h3 class="si-tool-card-title">Frais de notaire</h3>
            <p class="si-tool-card-desc">Calcul par d&eacute;partement, bar&egrave;me d&eacute;gressif</p>
          </div>
        </a>
        <a href="/pages/calculateur-capacite-emprunt" class="si-tool-card">
          <div class="si-tool-card-icon">
            <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/></svg>
          </div>
          <div>
            <h3 class="si-tool-card-title">Capacit&eacute; d&#39;emprunt</h3>
            <p class="si-tool-card-desc">Taux d&#39;endettement HCSF 35%, comparatif dur&eacute;es</p>
          </div>
        </a>
        <a href="/pages/calculateur-mensualite-credit" class="si-tool-card">
          <div class="si-tool-card-icon">
            <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V13.5zm0 2.25h.008v.008H8.25V15.75zm0 2.25h.008v.008H8.25V18zm2.498-6.75h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V13.5zm0 2.25h.007v.008h-.007V15.75zm0 2.25h.007v.008h-.007V18zm2.504-6.75h.008v.008H13.5v-.008zm0 2.25h.008v.008H13.5V13.5zm0 2.25h.008v.008H13.5V15.75zm2.25-4.5h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zm0 2.25h.008v.008h-.008V15.75zM6 6.75A.75.75 0 016.75 6h10.5a.75.75 0 01.75.75v10.5a.75.75 0 01-.75.75H6.75a.75.75 0 01-.75-.75V6.75z"/></svg>
          </div>
          <div>
            <h3 class="si-tool-card-title">Mensualit&eacute; de cr&eacute;dit</h3>
            <p class="si-tool-card-desc">Simulation avec tableau d&#39;amortissement</p>
          </div>
        </a>
        <a href="/pages/calculateur-rendement-locatif" class="si-tool-card">
          <div class="si-tool-card-icon">
            <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>
          </div>
          <div>
            <h3 class="si-tool-card-title">Rendement locatif</h3>
            <p class="si-tool-card-desc">Brut, net et net-net, micro-foncier vs r&eacute;el</p>
          </div>
        </a>
      </div>
    </div>

    <!-- CTA final -->
    <div style="text-align:center;margin-top:3rem;" class="si-reveal">
      <a href="https://app.score-immo.fr/app" class="si-btn si-btn-primary">
        Analyser une annonce
        <svg class="si-arrow" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-7-7 7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .si-guide-card {
    background: var(--si-card);
    border: 1px solid var(--si-border);
    border-radius: var(--si-radius-2xl);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .si-guide-card:hover {
    border-color: var(--si-accent);
    box-shadow: 0 4px 24px rgba(59,130,246,0.08);
  }
  .si-guide-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .si-guide-card-icon {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--si-radius);
    background: rgba(59,130,246,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--si-accent);
    flex-shrink: 0;
  }
  .si-guide-card-title {
    font-family: var(--si-font-heading);
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--si-foreground);
    line-height: 1.3;
    margin: 0;
  }
  .si-guide-card-count {
    font-size: 0.75rem;
    color: var(--si-muted-foreground);
    font-family: var(--si-font-body);
    margin: 0;
  }
  .si-guide-card-desc {
    font-size: 0.875rem;
    color: var(--si-muted-foreground);
    font-family: var(--si-font-body);
    line-height: 1.5;
    margin: 0 0 1rem 0;
  }
  .si-guide-article-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0;
    border-top: 1px solid var(--si-border);
    text-decoration: none;
    transition: background 0.15s;
  }
  .si-guide-article-link:hover {
    background: rgba(59,130,246,0.03);
  }
  .si-guide-article-thumb {
    width: 3rem;
    height: 3rem;
    border-radius: var(--si-radius);
    object-fit: cover;
    flex-shrink: 0;
  }
  .si-guide-article-thumb-placeholder {
    background: linear-gradient(135deg, var(--si-accent-light, rgba(59,130,246,0.06)), var(--si-secondary, rgba(59,130,246,0.03)));
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .si-guide-article-title {
    font-size: 0.8125rem;
    font-family: var(--si-font-body);
    color: var(--si-foreground);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .si-guide-card-empty {
    font-size: 0.8125rem;
    color: var(--si-muted-foreground);
    font-style: italic;
    text-align: center;
    padding: 1rem 0;
    margin: 0;
  }
  .si-guide-card-cta {
    margin-top: auto;
    padding-top: 1rem;
    align-self: flex-start;
    font-size: 0.8125rem;
  }

  .si-grid-2x2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  @media (max-width: 640px) {
    .si-grid-2x2 { grid-template-columns: 1fr; }
  }
  .si-tool-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--si-card);
    border: 1px solid var(--si-border);
    border-radius: var(--si-radius-2xl);
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .si-tool-card:hover {
    border-color: var(--si-accent);
    box-shadow: 0 4px 24px rgba(59,130,246,0.08);
  }
  .si-tool-card-icon {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--si-radius);
    background: rgba(59,130,246,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--si-accent);
    flex-shrink: 0;
  }
  .si-tool-card-title {
    font-family: var(--si-font-heading);
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--si-foreground);
    margin: 0 0 0.125rem 0;
  }
  .si-tool-card-desc {
    font-size: 0.75rem;
    color: var(--si-muted-foreground);
    font-family: var(--si-font-body);
    margin: 0;
    line-height: 1.4;
  }
</style>
