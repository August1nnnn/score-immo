---
---
<!-- ScoreImmo - Demo Report Mockup (faithful reproduction, auto-scroll) -->
<section class="si-section" style="padding-top:1rem;padding-bottom:2rem;">
  <div class="si-container" style="max-width:48rem;margin:0 auto;text-align:center;">

    <div class="si-dmk si-reveal" style="margin-top:0;">
      <a href="https://app.score-immo.fr/r/demo" class="si-dmk-link">
        <div class="si-dmk-badge">Rapport exemple</div>
        <div class="si-dmk-frame">
          <div class="si-dmk-scroll">

            <!-- ===== HEADER ===== -->
            <div style="padding:20px 16px 12px;text-align:left;">
              <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px;">
                <span style="display:inline-flex;align-items:center;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;background:#F1F5F9;color:#0F172A;">Appartement</span>
                <span style="display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;background:rgba(245,158,11,0.1);color:#D97706;">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  Quartier estime
                </span>
              </div>
              <h3 style="font-family:var(--si-font-heading);font-weight:700;font-size:1.25rem;margin:0;color:#0F172A;">Appartement T3 : 68 m&sup2;</h3>
              <p style="display:flex;align-items:center;gap:4px;font-size:0.8125rem;color:#64748B;margin:4px 0 0;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                Lyon 3e (69003)
              </p>
              <p style="font-size:0.75rem;color:#94A3B8;margin:2px 0 0;">12 rue des Lilas, 69003 Lyon</p>
            </div>

            <!-- ===== SCORE GAUGE ===== -->
            <div style="text-align:center;padding:16px 16px 20px;">
              <div style="position:relative;width:120px;height:120px;margin:0 auto;">
                <svg viewBox="0 0 100 100" style="width:100%;height:100%;transform:rotate(-90deg);">
                  <circle cx="50" cy="50" r="40" fill="none" stroke="#F1F5F9" stroke-width="7"/>
                  <circle cx="50" cy="50" r="40" fill="none" stroke="#F59E0B" stroke-width="7"
                    stroke-dasharray="251.3" stroke-dashoffset="65.3" stroke-linecap="round"
                    class="si-dmk-gauge-fill"/>
                </svg>
                <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;">
                  <span style="font-family:var(--si-font-heading);font-weight:800;font-size:2rem;color:#F59E0B;line-height:1;" class="si-dmk-score-num">74</span>
                  <span style="font-size:0.6875rem;color:#64748B;">/100</span>
                </div>
              </div>
              <span style="display:inline-block;margin-top:8px;padding:3px 12px;border-radius:20px;font-size:0.75rem;font-weight:600;background:rgba(245,158,11,0.1);color:#D97706;">Correct</span>

              <!-- Mini score bars -->
              <div style="display:flex;flex-direction:column;gap:6px;margin-top:16px;text-align:left;">
                <div style="display:flex;align-items:center;gap:8px;font-size:11px;">
                  <span style="width:100px;color:#64748B;white-space:nowrap;">Prix vs Marché</span>
                  <div style="flex:1;height:6px;border-radius:3px;background:#F1F5F9;overflow:hidden;">
                    <div style="width:80%;height:100%;border-radius:3px;background:#16A34A;" class="si-dmk-bar"></div>
                  </div>
                  <span style="font-weight:700;color:#16A34A;width:28px;text-align:right;">8/10</span>
                </div>
                <div style="display:flex;align-items:center;gap:8px;font-size:11px;">
                  <span style="width:100px;color:#64748B;white-space:nowrap;">Énergétique</span>
                  <div style="flex:1;height:6px;border-radius:3px;background:#F1F5F9;overflow:hidden;">
                    <div style="width:70%;height:100%;border-radius:3px;background:#16A34A;" class="si-dmk-bar"></div>
                  </div>
                  <span style="font-weight:700;color:#16A34A;width:28px;text-align:right;">7/10</span>
                </div>
                <div style="display:flex;align-items:center;gap:8px;font-size:11px;">
                  <span style="width:100px;color:#64748B;white-space:nowrap;">Risques</span>
                  <div style="flex:1;height:6px;border-radius:3px;background:#F1F5F9;overflow:hidden;">
                    <div style="width:70%;height:100%;border-radius:3px;background:#16A34A;" class="si-dmk-bar"></div>
                  </div>
                  <span style="font-weight:700;color:#16A34A;width:28px;text-align:right;">7/10</span>
                </div>
                <div style="display:flex;align-items:center;gap:8px;font-size:11px;">
                  <span style="width:100px;color:#64748B;white-space:nowrap;">Transports</span>
                  <div style="flex:1;height:6px;border-radius:3px;background:#F1F5F9;overflow:hidden;">
                    <div style="width:70%;height:100%;border-radius:3px;background:#16A34A;" class="si-dmk-bar"></div>
                  </div>
                  <span style="font-weight:700;color:#16A34A;width:28px;text-align:right;">7/10</span>
                </div>
                <div style="display:flex;align-items:center;gap:8px;font-size:11px;">
                  <span style="width:100px;color:#64748B;white-space:nowrap;">Commerces</span>
                  <div style="flex:1;height:6px;border-radius:3px;background:#F1F5F9;overflow:hidden;">
                    <div style="width:80%;height:100%;border-radius:3px;background:#16A34A;" class="si-dmk-bar"></div>
                  </div>
                  <span style="font-weight:700;color:#16A34A;width:28px;text-align:right;">8/10</span>
                </div>
                <div style="display:flex;align-items:center;gap:8px;font-size:11px;">
                  <span style="width:100px;color:#64748B;white-space:nowrap;">Environnement</span>
                  <div style="flex:1;height:6px;border-radius:3px;background:#F1F5F9;overflow:hidden;">
                    <div style="width:60%;height:100%;border-radius:3px;background:#F59E0B;" class="si-dmk-bar"></div>
                  </div>
                  <span style="font-weight:700;color:#F59E0B;width:28px;text-align:right;">6/10</span>
                </div>
              </div>
            </div>

            <!-- ===== PRIX VS MARCHÉ ===== -->
            <div style="padding:0 16px 12px;">
              <div style="background:#fff;border-radius:16px;padding:16px;box-shadow:0 1px 4px rgba(0,0,0,0.04);">
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="1.5"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
                  <span style="font-family:var(--si-font-heading);font-weight:700;font-size:0.875rem;">Prix &amp; Marché</span>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px;">
                  <div style="background:#F8FAFC;border-radius:10px;padding:10px;text-align:center;">
                    <p style="font-size:0.5625rem;color:#94A3B8;text-transform:uppercase;letter-spacing:0.05em;">Prix affiche</p>
                    <p style="font-family:var(--si-font-heading);font-weight:700;font-size:0.9375rem;">285 000 &euro;</p>
                  </div>
                  <div style="background:#F8FAFC;border-radius:10px;padding:10px;text-align:center;">
                    <p style="font-size:0.5625rem;color:#94A3B8;text-transform:uppercase;letter-spacing:0.05em;">Surface</p>
                    <p style="font-family:var(--si-font-heading);font-weight:700;font-size:0.9375rem;">68 m&sup2;</p>
                  </div>
                  <div style="background:#F8FAFC;border-radius:10px;padding:10px;text-align:center;">
                    <p style="font-size:0.5625rem;color:#94A3B8;text-transform:uppercase;letter-spacing:0.05em;">&euro;/m&sup2; annonce</p>
                    <p style="font-family:var(--si-font-heading);font-weight:700;font-size:0.9375rem;">4 191 &euro;</p>
                  </div>
                  <div style="background:#F8FAFC;border-radius:10px;padding:10px;text-align:center;">
                    <p style="font-size:0.5625rem;color:#94A3B8;text-transform:uppercase;letter-spacing:0.05em;">Médiane locale</p>
                    <p style="font-family:var(--si-font-heading);font-weight:700;font-size:0.9375rem;">4 450 &euro;/m&sup2;</p>
                  </div>
                </div>
                <div style="padding:10px;border-radius:10px;background:rgba(22,163,74,0.08);color:#16A34A;font-size:0.8125rem;font-weight:600;display:flex;align-items:center;gap:6px;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
                  5,8% sous la médiane locale, signal favorable
                </div>
              </div>
            </div>

            <!-- ===== COÛT ACQUISITION ===== -->
            <div style="padding:0 16px 12px;">
              <div style="background:#fff;border-radius:16px;padding:16px;box-shadow:0 1px 4px rgba(0,0,0,0.04);">
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="1.5"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="12" y2="14"/></svg>
                  <span style="font-family:var(--si-font-heading);font-weight:700;font-size:0.875rem;">Coût total d'acquisition</span>
                </div>
                <div style="font-size:0.8125rem;display:flex;flex-direction:column;gap:6px;">
                  <div style="display:flex;justify-content:space-between;"><span style="color:#64748B;">Prix du bien</span><span style="font-weight:600;">285 000 &euro;</span></div>
                  <div style="display:flex;justify-content:space-between;"><span style="color:#64748B;">Frais de notaire (7,8%)</span><span>22 230 &euro;</span></div>
                  <div style="display:flex;justify-content:space-between;"><span style="color:#64748B;">Frais d'agence (5%)</span><span>14 250 &euro;</span></div>
                  <div style="display:flex;justify-content:space-between;border-top:1px solid #E2E8F0;padding-top:8px;margin-top:4px;">
                    <span style="font-weight:700;">Coût total</span>
                    <span style="font-family:var(--si-font-heading);font-weight:700;font-size:1rem;color:#3B82F6;">321 480 &euro;</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- ===== DPE ===== -->
            <div style="padding:0 16px 24px;">
              <div style="background:#fff;border-radius:16px;padding:16px;box-shadow:0 1px 4px rgba(0,0,0,0.04);">
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="1.5"><path d="M14 4v10.54a4 4 0 11-4 0V4a2 2 0 014 0z"/></svg>
                  <span style="font-family:var(--si-font-heading);font-weight:700;font-size:0.875rem;">Performance Énergétique</span>
                </div>
                <!-- DPE Scale -->
                <div style="display:flex;gap:3px;margin-bottom:12px;">
                  <div style="flex:1;height:28px;border-radius:6px;background:#319834;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:11px;">A</div>
                  <div style="flex:1;height:28px;border-radius:6px;background:#33a357;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:11px;">B</div>
                  <div style="flex:1;height:28px;border-radius:6px;background:#cbdb2a;display:flex;align-items:center;justify-content:center;color:#000;font-weight:700;font-size:11px;outline:2px solid #0F172A;outline-offset:1px;transform:scale(1.1);">C</div>
                  <div style="flex:1;height:28px;border-radius:6px;background:#f3ec02;display:flex;align-items:center;justify-content:center;color:#000;font-weight:700;font-size:11px;">D</div>
                  <div style="flex:1;height:28px;border-radius:6px;background:#f0b40a;display:flex;align-items:center;justify-content:center;color:#000;font-weight:700;font-size:11px;">E</div>
                  <div style="flex:1;height:28px;border-radius:6px;background:#ef6e22;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:11px;">F</div>
                  <div style="flex:1;height:28px;border-radius:6px;background:#d7221f;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:11px;">G</div>
                </div>
                <div style="display:flex;gap:12px;align-items:center;">
                  <div style="width:48px;height:48px;border-radius:12px;background:#cbdb2a;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:1.25rem;color:#000;">C</div>
                  <div>
                    <p style="font-size:0.8125rem;font-weight:600;">DPE C : 244 kWh/m&sup2;/an</p>
                    <p style="font-size:0.75rem;color:#64748B;">GES B : 8 kg CO&sub2;/m&sup2;/an</p>
                  </div>
                </div>
              </div>
            </div>

          </div>
        </div>

        <div class="si-dmk-cta">Voir le rapport complet</div>
      </a>
    </div>

  </div>
</section>

<style>
.si-dmk{max-width:700px;margin:0 auto;position:relative;}
.si-dmk-link{display:block;text-decoration:none;color:inherit;position:relative;}
.si-dmk-badge{position:absolute;top:12px;left:12px;z-index:3;background:rgba(255,255,255,0.88);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);font-size:0.6875rem;font-weight:600;color:var(--si-accent);padding:4px 10px;border-radius:20px;border:1px solid rgba(59,130,246,0.15);}
.si-dmk-frame{border-radius:24px;border:1px solid #E2E8F0;background:#F8FAFC;overflow:hidden;height:480px;position:relative;box-shadow:0 8px 40px rgba(0,0,0,0.08);animation:si-dmk-glow 3s ease-in-out infinite;}
.si-dmk-scroll{animation:si-dmk-auto 38s ease-in-out infinite;}
.si-dmk-frame:hover .si-dmk-scroll{animation-play-state:paused;}
.si-dmk-cta{position:absolute;bottom:0;left:0;right:0;z-index:2;background:linear-gradient(to top,rgba(248,250,252,0.97) 50%,transparent);padding:3rem 1rem 1.25rem;text-align:center;font-family:var(--si-font-heading);font-weight:700;font-size:0.875rem;color:var(--si-accent);border-radius:0 0 24px 24px;}

/* Gauge fill animation */
.si-dmk-gauge-fill{stroke-dashoffset:251.3;animation:si-dmk-gauge 1.2s ease-out 0.5s forwards;}
/* Score bars animation */
.si-dmk-bar{transform:scaleX(0);transform-origin:left;animation:si-dmk-barfill 0.8s ease-out 1s forwards;}
/* Score number count-up */
.si-dmk-score-num{opacity:0;animation:si-dmk-fadein 0.3s ease-out 1.5s forwards;}

@keyframes si-dmk-auto{
  0%,6%{transform:translateY(0);}
  46%,54%{transform:translateY(calc(-100% + 480px));}
  94%,100%{transform:translateY(0);}
}
@keyframes si-dmk-glow{
  0%,100%{box-shadow:0 8px 40px rgba(0,0,0,0.08);}
  50%{box-shadow:0 8px 40px rgba(59,130,246,0.12),0 0 0 1px rgba(59,130,246,0.08);}
}
@keyframes si-dmk-gauge{to{stroke-dashoffset:65.3;}}
@keyframes si-dmk-barfill{to{transform:scaleX(1);}}
@keyframes si-dmk-fadein{to{opacity:1;}}

@media(max-width:640px){
  .si-dmk{max-width:340px;}
  .si-dmk-frame{height:400px;}
  @keyframes si-dmk-auto{
    0%,6%{transform:translateY(0);}
    46%,54%{transform:translateY(calc(-100% + 400px));}
    94%,100%{transform:translateY(0);}
  }
}
</style>
