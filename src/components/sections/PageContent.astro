<!-- ScoreImmo - Generic Page Content Section -->
<section class="si-section">
  <div class="si-container" style="max-width:48rem;">
    
      <h1 class="si-section-title" style="font-size:2rem;text-align:left;margin-bottom:2rem;"></h1>
    
    <div class="si-page-content" style="font-family:var(--si-font-body);color:var(--si-foreground);line-height:1.75;font-size:0.9375rem;">
      
    </div>
  </div>
</section>

<style>
  .si-page-content h2 {
    font-family: var(--si-font-heading);
    font-weight: 700;
    font-size: 1.5rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--si-foreground);
  }
  .si-page-content h3 {
    font-family: var(--si-font-heading);
    font-weight: 600;
    font-size: 1.25rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .si-page-content p {
    margin-bottom: 1rem;
    color: var(--si-muted-foreground);
  }
  .si-page-content ul, .si-page-content ol {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    color: var(--si-muted-foreground);
  }
  .si-page-content li {
    margin-bottom: 0.375rem;
  }
  .si-page-content a {
    color: var(--si-accent);
    text-decoration: underline;
  }
  .si-page-content a:hover {
    color: var(--si-foreground);
  }
  @media (max-width: 768px) {
    .si-page-content {
      padding: 20px 16px;
    }
  }
</style>
