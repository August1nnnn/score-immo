---
// GA4 tracker — runs ALONGSIDE the existing Supabase tracker (Mix mode).
// Same consent gate as Analytics.astro: respects `si_cookie_consent` localStorage
// (only suppress full GA4 if explicitly rejected).
const GA4_ID = "G-FL8T0DN7GH";
---

<script define:vars={{ GA4_ID }}>
  (function () {
    try {
      const v = JSON.parse(localStorage.getItem("si_cookie_consent") || "null");
      if (v && v.status === "rejected") return;
    } catch (e) {}

    const s = document.createElement("script");
    s.async = true;
    s.src = "https://www.googletagmanager.com/gtag/js?id=" + GA4_ID;
    document.head.appendChild(s);

    window.dataLayer = window.dataLayer || [];
    function gtag() {
      window.dataLayer.push(arguments);
    }
    window.gtag = gtag;
    gtag("js", new Date());
    gtag("config", GA4_ID);
  })();
</script>
