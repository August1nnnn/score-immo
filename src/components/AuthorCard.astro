---
interface Props {
  author: {
    handle: string;
    name: string;
    title: string;
    bio?: string;
    avatar_initials: string;
    avatar_color: string;
    years_experience?: number;
  };
  publishedAt?: string;
  lastReviewed?: string;
  compact?: boolean;
}
const { author, publishedAt, lastReviewed, compact = false } = Astro.props;

const fmt = (iso?: string | null) =>
  iso ? new Date(iso).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' }) : null;
---
<div class={`si-author ${compact ? 'si-author-compact' : ''}`}>
  <a href={`/pages/auteurs/${author.handle}`} class="si-author-avatar" style={`background:${author.avatar_color};`}>
    {author.avatar_initials}
  </a>
  <div class="si-author-meta">
    <a href={`/pages/auteurs/${author.handle}`} class="si-author-name">
      {author.name}
    </a>
    <div class="si-author-title">
      {author.title}{author.years_experience ? ` · ${author.years_experience} ans d'expérience` : ''}
    </div>
    {(publishedAt || lastReviewed) && (
      <div class="si-author-dates">
        {publishedAt && <span>Publié le {fmt(publishedAt)}</span>}
        {lastReviewed && publishedAt && <span> · </span>}
        {lastReviewed && <span>Relu le {fmt(lastReviewed)}</span>}
      </div>
    )}
  </div>
</div>

<style>
  .si-author {
    display: flex;
    gap: 0.875rem;
    align-items: center;
    padding: 0.75rem 0;
  }
  .si-author-avatar {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-family: var(--si-font-heading, 'DM Sans', sans-serif);
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    letter-spacing: -0.02em;
  }
  .si-author-meta { display: flex; flex-direction: column; gap: 0.125rem; }
  .si-author-name {
    font-family: var(--si-font-heading, 'DM Sans', sans-serif);
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--si-foreground, #0F172A);
    text-decoration: none;
    line-height: 1.3;
  }
  .si-author-name:hover { color: var(--si-accent, #3B82F6); }
  .si-author-title {
    font-size: 0.8125rem;
    color: var(--si-muted-foreground, #64748B);
    line-height: 1.4;
  }
  .si-author-dates {
    font-size: 0.75rem;
    color: var(--si-muted-foreground, #64748B);
    margin-top: 0.125rem;
  }
  .si-author-compact .si-author-avatar { width: 36px; height: 36px; font-size: 0.8125rem; }
  .si-author-compact .si-author-name { font-size: 0.875rem; }
  .si-author-compact .si-author-title { font-size: 0.75rem; }
</style>
