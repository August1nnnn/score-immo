---
import BaseLayout from '@/layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  const dir = path.resolve('./src/data/pages');
  const files = fs.readdirSync(dir).filter((f) => f.endsWith('.json'));
  return files.map((f) => {
    const p = JSON.parse(fs.readFileSync(path.join(dir, f), 'utf-8'));
    return {
      params: { slug: p.handle },
      props: { page: p },
    };
  });
}

const { page } = Astro.props;

const title = page.title ? `${page.title} | ScoreImmo` : 'ScoreImmo';
const description = page.body_html
  ? page.body_html.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').slice(0, 160).trim()
  : 'ScoreImmo - Analyse immobilière en 30 secondes';

// Sanitize body_html for safe render (Shopify source is trusted)
const bodyHtml = page.body_html || '';

// Legal pages + contact get noindex=false but canonical strict
const noindex = page.handle === 'llms-txt' ? true : false;
---
<BaseLayout {title} {description} {noindex}>
  <section class="si-section">
    <div class="si-container">
      <article class="si-page-content" set:html={bodyHtml}></article>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .si-page-content {
    max-width: 48rem;
    margin: 0 auto;
    padding: 2rem 0;
  }
  .si-page-content h1,
  .si-page-content h2,
  .si-page-content h3 {
    font-family: var(--si-font-heading, 'DM Sans', sans-serif);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--si-foreground, #0F172A);
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  .si-page-content h1 { font-size: clamp(2rem, 5vw, 3rem); line-height: 1.1; }
  .si-page-content h2 { font-size: clamp(1.5rem, 3.5vw, 2.25rem); line-height: 1.2; }
  .si-page-content h3 { font-size: clamp(1.25rem, 2.5vw, 1.5rem); }
  .si-page-content p { margin: 0 0 1rem; line-height: 1.7; color: var(--si-foreground, #0F172A); }
  .si-page-content ul, .si-page-content ol { margin: 0 0 1rem 1.5rem; line-height: 1.7; }
  .si-page-content li { margin-bottom: 0.5rem; }
  .si-page-content a { color: var(--si-accent, #3B82F6); text-decoration: underline; }
  .si-page-content a:hover { color: var(--si-accent-hover, rgba(59,130,246,0.9)); }
  .si-page-content blockquote {
    border-left: 4px solid var(--si-accent, #3B82F6);
    padding: 0.5rem 0 0.5rem 1rem;
    margin: 1rem 0;
    color: var(--si-muted-foreground, #64748B);
    font-style: italic;
  }
  .si-page-content img {
    max-width: 100%;
    height: auto;
    border-radius: var(--si-radius, 0.75rem);
    margin: 1rem 0;
  }
  .si-page-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
  }
  .si-page-content th,
  .si-page-content td {
    padding: 0.75rem;
    border: 1px solid var(--si-border, #E2E8F0);
    text-align: left;
  }
  .si-page-content th {
    background: var(--si-muted, #F1F5F9);
    font-weight: 600;
  }
  .si-page-content code {
    background: var(--si-muted, #F1F5F9);
    padding: 0.15rem 0.35rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
  }
</style>
