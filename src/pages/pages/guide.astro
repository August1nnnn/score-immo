---
import BaseLayout from '@/layouts/BaseLayout.astro';
import GuideHub from '@/components/sections/GuideHub.astro';

const title = "Le Guide de l'Acheteur - ScoreImmo";
const description = "Le hub éditorial ScoreImmo : guides, prix par ville, meilleurs quartiers, calculateurs. Tout pour acheter au bon prix en France.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Le Guide de l'Acheteur - ScoreImmo",
    "description": description,
    "url": "https://score-immo.fr/pages/guide",
    "isPartOf": { "@id": "https://score-immo.fr/#website" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://score-immo.fr/" },
      { "@type": "ListItem", "position": 2, "name": "Guide de l'acheteur", "item": "https://score-immo.fr/pages/guide" }
    ]
  }
];
---
<BaseLayout {title} {description} {jsonLd}>
  <GuideHub />
</BaseLayout>
