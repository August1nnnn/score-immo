---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Pricing from '@/components/sections/Pricing.astro';

const title = "Tarifs ScoreImmo - 1€ le premier mois, sans engagement";
const description = "Découvre tous les tarifs ScoreImmo : 1ère analyse offerte, Découverte 9,99€, Recherche 29€/mois, Premium 79€/mois. Sans engagement, annulable en 1 clic.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "ScoreImmo - Analyse immobilière",
    "description": "Rapport complet d'aide à la décision immobilière, 230+ données croisées depuis 9 sources officielles.",
    "brand": { "@type": "Brand", "name": "ScoreImmo" },
    "offers": [
      {
        "@type": "Offer",
        "name": "Découverte",
        "price": "9.99",
        "priceCurrency": "EUR",
        "description": "5 analyses, paiement unique, sans engagement",
        "availability": "https://schema.org/InStock",
        "url": "https://app.score-immo.fr/app"
      },
      {
        "@type": "Offer",
        "name": "Recherche",
        "price": "29",
        "priceCurrency": "EUR",
        "description": "60 analyses/mois, 1€ le premier mois, sans engagement",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "29",
          "priceCurrency": "EUR",
          "billingDuration": "P1M",
          "unitText": "MONTH"
        },
        "availability": "https://schema.org/InStock",
        "url": "https://app.score-immo.fr/app"
      },
      {
        "@type": "Offer",
        "name": "Premium",
        "price": "79",
        "priceCurrency": "EUR",
        "description": "Analyses illimitées, 1€ le premier mois, sans engagement",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "79",
          "priceCurrency": "EUR",
          "billingDuration": "P1M",
          "unitText": "MONTH"
        },
        "availability": "https://schema.org/InStock",
        "url": "https://app.score-immo.fr/app"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://score-immo.fr/" },
      { "@type": "ListItem", "position": 2, "name": "Tarifs", "item": "https://score-immo.fr/pages/tarifs" }
    ]
  }
];
---
<BaseLayout {title} {description} {jsonLd}>
  <Pricing />
</BaseLayout>
