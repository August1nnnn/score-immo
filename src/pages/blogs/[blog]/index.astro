---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return [
    { params: { blog: 'guides' } },
    { params: { blog: 'villes' } },
    { params: { blog: 'quartiers' } },
  ];
}

const { blog } = Astro.params;
const articles = (await getCollection('articles', (e) => e.data.blog === blog))
  .sort((a, b) => new Date(b.data.published_at).getTime() - new Date(a.data.published_at).getTime());

const titles: Record<string, string> = {
  guides: "Le Guide de l'Acheteur - Conseils immobiliers",
  villes: "Prix Immobilier par Ville 2026 - Analyses complètes",
  quartiers: "Meilleurs Quartiers pour Acheter - Guide 2026",
};
const descriptions: Record<string, string> = {
  guides: "Nos guides pratiques pour acheter en confiance : DPE, négociation, frais de notaire, prêt, SCI, premier achat. Conseils concrets et chiffrés.",
  villes: "Analyse du marché immobilier par ville : Lyon, Paris, Marseille, Bordeaux, Nantes, Toulouse et plus. Prix au m², tendances 2026.",
  quartiers: "Les meilleurs quartiers pour acheter : analyses détaillées par ville. Où investir, où habiter, qualité de vie et prix.",
};

const title = `${titles[blog!]} | ScoreImmo`;
const description = descriptions[blog!];

const labels: Record<string, string> = {
  guides: "Guide de l'acheteur",
  villes: 'Prix par ville',
  quartiers: 'Meilleurs quartiers',
};

const canonical = `https://score-immo.fr/blogs/${blog}`;

const jsonLd: any[] = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": titles[blog!],
    "description": descriptions[blog!],
    "url": canonical,
    "isPartOf": { "@id": "https://score-immo.fr/#website" },
    "hasPart": articles.map((a) => ({
      "@type": "Article",
      "headline": a.data.title,
      "url": `https://score-immo.fr/blogs/${a.data.blog}/${a.data.handle}`,
      "datePublished": a.data.published_at,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://score-immo.fr/" },
      { "@type": "ListItem", "position": 2, "name": labels[blog!], "item": canonical },
    ],
  },
];

if (blog === 'villes') {
  jsonLd.push({
    "@context": "https://schema.org",
    "@type": "Dataset",
    "name": "Prix immobilier par ville 2026 - ScoreImmo",
    "description": "Analyses chiffrées du marché immobilier français par ville. Prix au m², évolution, tendances par arrondissement/quartier. Données sourcées DVF, INSEE, notaires de France.",
    "url": canonical,
    "license": "https://creativecommons.org/licenses/by/4.0/",
    "creator": { "@id": "https://score-immo.fr/#organization" },
    "keywords": ["prix immobilier France", "prix m² par ville", "marché immobilier résidentiel", "DVF", "évolution prix immobilier 2026"],
    "spatialCoverage": { "@type": "Place", "name": "France" },
    "temporalCoverage": "2025-01-01/2026-12-31",
    "isBasedOn": [
      { "@type": "Dataset", "name": "Demandes de valeurs foncières (DVF)", "url": "https://www.data.gouv.fr/fr/datasets/demandes-de-valeurs-foncieres-geolocalisees/" },
      { "@type": "Dataset", "name": "Recensement INSEE", "url": "https://www.insee.fr/fr/statistiques/serie/001515333" },
    ],
  });
}
---
<BaseLayout {title} {description} {canonical} {jsonLd}>
  <section class="si-section">
    <div class="si-container">
      <div class="si-blog-header">
        <h1 class="si-section-title">{labels[blog!]}</h1>
        <p class="si-section-subtitle">{descriptions[blog!]}</p>
      </div>

      <div class="si-grid-3">
        {articles.map((a) => (
          <a href={`/blogs/${a.data.blog}/${a.data.handle}`} class="si-blog-card">
            {a.data.image?.src && (
              <img
                src={a.data.image.src}
                alt={a.data.image.alt || a.data.title}
                loading="lazy"
                width="600"
                height="400"
              />
            )}
            <div class="si-blog-card-body">
              <h3 class="si-blog-card-title">{a.data.title}</h3>
              <p class="si-blog-card-excerpt">{a.data.meta_description?.slice(0, 150)}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .si-blog-header {
    text-align: center;
    max-width: 40rem;
    margin: 0 auto 3rem;
  }
</style>
