---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TLDRBox from '@/components/TLDRBox.astro';
import AuthorCard from '@/components/AuthorCard.astro';
import SourcesSection from '@/components/SourcesSection.astro';
import AnalyzerBox from '@/components/AnalyzerBox.astro';
import BarometreLinks from '@/components/BarometreLinks.astro';
import ProValueCTA from '@/components/ProValueCTA.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((entry) => ({
    params: { blog: entry.data.blog, slug: entry.data.handle },
    props: { article: entry.data },
  }));
}

const { article } = Astro.props;

// Fetch author
const authorHandle = article.author_handle || 'lea-moreau';
const authorEntry = await getEntry('authors', authorHandle);
const author = authorEntry?.data;

const title = article.meta_title || `${article.title} | ScoreImmo`;
const description = article.meta_description || article.title;
const image = article.image?.src;
const canonical = `https://score-immo.fr/blogs/${article.blog}/${article.handle}`;

const blogLabels: Record<string, string> = {
  guides: "Guide de l'acheteur",
  villes: 'Prix par ville',
  quartiers: 'Meilleurs quartiers',
  pro: 'Espace mandataires',
};

// Extract FAQ pairs from body_html (h2 "FAQ" block, then h3 questions + p answers)
function extractFaq(html: string): { q: string; a: string }[] {
  const faqAnchor = html.match(/<h2[^>]*>\s*FAQ[^<]*<\/h2>/i);
  if (!faqAnchor || faqAnchor.index === undefined) return [];
  const after = html.slice(faqAnchor.index + faqAnchor[0].length);
  const pairs: { q: string; a: string }[] = [];
  const re = /<h3[^>]*>([\s\S]*?)<\/h3>\s*((?:<p[^>]*>[\s\S]*?<\/p>\s*)+)/gi;
  let m: RegExpExecArray | null;
  while ((m = re.exec(after)) !== null) {
    const q = m[1].replace(/<[^>]+>/g, '').trim();
    const a = m[2].replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
    if (q && a) pairs.push({ q, a });
  }
  return pairs;
}
const faqPairs = extractFaq(article.body_html || '');

// Build JSON-LD
const jsonLd: any[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: article.title,
    description,
    image: image ? [image.startsWith('http') ? image : `https://score-immo.fr${image}`] : undefined,
    datePublished: article.published_at,
    dateModified: article.last_reviewed || article.updated_at || article.published_at,
    author: author ? {
      '@type': 'Person',
      name: author.name,
      jobTitle: author.title,
      url: `https://score-immo.fr/pages/auteurs/${author.handle}`,
      knowsAbout: author.expertise,
    } : { '@type': 'Organization', name: 'ScoreImmo' },
    publisher: {
      '@type': 'Organization',
      name: 'ScoreImmo',
      logo: { '@type': 'ImageObject', url: 'https://score-immo.fr/favicon.svg' },
    },
    mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
    inLanguage: 'fr-FR',
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['.si-article-title', '.si-tldr', '.si-article-body h2', '.si-article-body h3'],
    },
    ...(article.word_count ? { wordCount: article.word_count } : {}),
    ...(article.sources && article.sources.length > 0 ? {
      citation: article.sources.map((s) => ({
        '@type': 'CreativeWork',
        name: s.title,
        url: s.url,
        ...(s.publisher ? { publisher: { '@type': 'Organization', name: s.publisher } } : {}),
      })),
    } : {}),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://score-immo.fr/' },
      { '@type': 'ListItem', position: 2, name: blogLabels[article.blog], item: `https://score-immo.fr/blogs/${article.blog}` },
      { '@type': 'ListItem', position: 3, name: article.title, item: canonical },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': canonical,
    url: canonical,
    name: article.meta_title || article.title,
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['.si-article-title', '.si-tldr', '.si-article-body h2', '.si-article-body h3'],
    },
    inLanguage: 'fr-FR',
  },
];

if (faqPairs.length > 0) {
  jsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqPairs.map(({ q, a }) => ({
      '@type': 'Question',
      name: q,
      acceptedAnswer: { '@type': 'Answer', text: a },
    })),
  });
}

// First-party methodology Dataset — only on the canonical "Score ScoreImmo" method page.
// Makes the named, weighted scoring methodology a citable primary source for LLMs.
// Weights are the production source of truth (app scoringService.ts):
// market 40% + risks 20% + energy 15% + neighborhood 15% + liquidity 10%.
if (article.handle === 'score-scoreimmo-methode-evaluation') {
  jsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'Dataset',
    '@id': `${canonical}#methodologie`,
    name: 'Méthodologie du Score ScoreImmo',
    alternateName: 'Score ScoreImmo',
    description:
      "Méthodologie de notation immobilière ScoreImmo : une note sur 100 calculée en croisant plus de 250 données de 10 sources publiques officielles. Le score agrège cinq sous-scores pondérés : prix face au marché 40 %, risques 20 %, performance énergétique 15 %, environnement et quartier 15 %, liquidité 10 %.",
    url: canonical,
    isAccessibleForFree: true,
    inLanguage: 'fr-FR',
    datePublished: article.published_at,
    dateModified: article.last_reviewed || article.updated_at || article.published_at,
    creator: { '@id': 'https://score-immo.fr/#organization' },
    publisher: { '@id': 'https://score-immo.fr/#organization' },
    measurementTechnique:
      "Agrégation pondérée de cinq sous-scores (prix vs marché DVF, risques Géorisques, performance énergétique DPE/ADEME, environnement et quartier, liquidité) en une note unique sur 100, accompagnée d'un indice de confiance A, B ou C selon la précision de géolocalisation et la couverture des sources.",
    variableMeasured: [
      { '@type': 'PropertyValue', name: 'Prix face au marché (DVF)', description: 'Écart au prix de vente réel médian des biens comparables.', value: '40%' },
      { '@type': 'PropertyValue', name: 'Risques naturels et technologiques (Géorisques)', description: 'Inondation, retrait-gonflement des argiles, séisme, radon, sites ICPE et Seveso.', value: '20%' },
      { '@type': 'PropertyValue', name: 'Performance énergétique (DPE/ADEME)', description: 'Classe DPE de A à G et impact sur la valeur et la louabilité.', value: '15%' },
      { '@type': 'PropertyValue', name: 'Environnement et quartier', description: 'Commerces, transports, écoles, services et profil socio-démographique INSEE.', value: '15%' },
      { '@type': 'PropertyValue', name: 'Liquidité du bien', description: 'Nombre de biens comparables disponibles dans le secteur.', value: '10%' },
    ],
    keywords: ['score immobilier', 'notation immobilière', 'méthode ScoreImmo', 'DVF', 'DPE', 'Géorisques', 'INSEE'],
  });
}
---
<BaseLayout
  {title}
  {description}
  image={image}
  {canonical}
  {jsonLd}
  articleMeta={{
    publishedTime: article.published_at,
    modifiedTime: article.last_reviewed || article.updated_at || article.published_at,
    author: author?.name || 'ScoreImmo',
  }}
>
  <section class="si-section">
    <div class="si-container">
      <nav class="si-breadcrumb" aria-label="Fil d'Ariane">
        <a href="/">Accueil</a>
        <span> &rsaquo; </span>
        <a href={`/blogs/${article.blog}`}>{blogLabels[article.blog]}</a>
        <span> &rsaquo; </span>
        <span>{article.title}</span>
      </nav>

      <article class="si-article">
        <header class="si-article-header">
          <h1 class="si-article-title">{article.title}</h1>
          {author && (
            <AuthorCard
              author={author}
              publishedAt={article.published_at}
              lastReviewed={article.last_reviewed || article.updated_at}
            />
          )}
          {image && (
            <img
              src={image}
              alt={article.image?.alt || article.title}
              width={article.image?.width || 1200}
              height={article.image?.height || 630}
              class="si-article-hero"
              loading="eager"
              fetchpriority="high"
            />
          )}
        </header>

        {article.tldr && article.tldr.length > 0 && (
          <TLDRBox items={article.tldr} />
        )}

        <AnalyzerBox blog={article.blog} medium="blog_top" />

        <div class="si-article-body" set:html={article.body_html}></div>

        {(article.blog === 'villes' || article.blog === 'quartiers') && (
          <BarometreLinks title={article.title} blog={article.blog} />
        )}

        {article.blog === 'pro' && <ProValueCTA />}

        {article.sources && article.sources.length > 0 && (
          <SourcesSection sources={article.sources} />
        )}

        <p class="si-article-disclaimer">
          Contenu informatif fondé sur des données publiques officielles, à jour à la date de révision indiquée. Ne constitue pas un conseil en investissement ni un avis juridique ou fiscal personnalisé.
        </p>

        {author && (
          <aside class="si-article-author-footer">
            <h3>À propos de l'auteur</h3>
            <AuthorCard author={author} />
            <p class="si-article-author-bio">{author.bio}</p>
          </aside>
        )}

        <footer class="si-article-footer">
          <AnalyzerBox blog={article.blog} medium="blog_end" />
        </footer>
      </article>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .si-breadcrumb {
    font-size: 0.875rem;
    color: var(--si-muted-foreground, #64748B);
    margin: 1rem 0 2rem;
  }
  .si-breadcrumb a { color: var(--si-muted-foreground, #64748B); text-decoration: none; }
  .si-breadcrumb a:hover { color: var(--si-accent, #3B82F6); }

  .si-article { max-width: 48rem; margin: 0 auto; }
  .si-article-title {
    font-family: var(--si-font-heading, 'DM Sans', sans-serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin: 0 0 1.25rem;
    color: var(--si-foreground);
  }
  .si-article-hero {
    width: 100%;
    height: auto;
    border-radius: var(--si-radius, 0.75rem);
    margin: 1.5rem 0 2rem;
  }
  .si-article-body h2 {
    font-family: var(--si-font-heading);
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 700;
    margin: 2.5rem 0 1rem;
    color: var(--si-foreground);
  }
  .si-article-body h3 {
    font-family: var(--si-font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
  }
  .si-article-body p { margin: 0 0 1rem; line-height: 1.75; font-size: 1.05rem; }
  .si-article-body ul, .si-article-body ol { margin: 0 0 1rem 1.5rem; line-height: 1.75; }
  .si-article-body li { margin-bottom: 0.5rem; }
  .si-article-body a { color: var(--si-accent); text-decoration: underline; }
  .si-article-body blockquote {
    border-left: 4px solid var(--si-accent);
    padding: 0.5rem 0 0.5rem 1rem;
    margin: 1.5rem 0;
    color: var(--si-muted-foreground);
    font-style: italic;
  }
  .si-article-body img { max-width: 100%; height: auto; border-radius: var(--si-radius); margin: 1.5rem 0; }
  .si-article-body table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.95rem; }
  .si-article-body th, .si-article-body td {
    padding: 0.75rem;
    border: 1px solid var(--si-border);
    text-align: left;
  }
  .si-article-body th { background: var(--si-muted); font-weight: 600; }

  .si-article-author-footer {
    margin-top: 2.5rem;
    padding: 1.5rem 1.75rem;
    border: 1px solid var(--si-border);
    border-radius: var(--si-radius);
    background: var(--si-card, #fff);
  }
  .si-article-author-footer h3 {
    font-family: var(--si-font-heading);
    font-size: 0.9375rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--si-muted-foreground);
    margin: 0 0 0.75rem;
  }
  .si-article-author-bio {
    margin: 0.75rem 0 0;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--si-foreground);
  }

  .si-article-disclaimer {
    margin: 1.5rem 0 0;
    padding-top: 1rem;
    border-top: 1px solid var(--si-border);
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--si-muted-foreground);
  }

  .si-cta-box {
    margin-top: 3rem;
    padding: 2rem;
    background: linear-gradient(135deg, var(--si-primary, #0F172A), #1e293b);
    color: #fff;
    border-radius: var(--si-radius-xl, 1rem);
    text-align: center;
  }
  .si-cta-box h3 {
    font-family: var(--si-font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: #fff;
  }
  .si-cta-box p { margin: 0 0 1.5rem; color: rgba(255,255,255,0.85); }
</style>
