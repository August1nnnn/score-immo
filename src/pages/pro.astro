---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AnalyzerBox from '@/components/AnalyzerBox.astro';

const SITE = 'https://score-immo.fr';
const canonical = `${SITE}/pro`;
const appUrl = 'https://app.score-immo.fr/app?utm_source=site&utm_medium=pro_landing';

const title = "ScoreImmo Pro : l'outil d'analyse des mandataires";
const description = "L'outil d'estimation et d'analyse pour les mandataires immobiliers : un rapport objectif sur 100, à votre marque, pour décrocher des mandats et rassurer vos clients.";

const faq = [
  { q: "ScoreImmo, c'est pour quels professionnels de l'immobilier ?", a: "Pour les mandataires immobiliers (IAD, SAFTI, Capifrance, Efficity, indépendants), les agents et les négociateurs qui veulent estimer juste et remettre une analyse objective à leurs clients vendeurs et acheteurs." },
  { q: "Qu'est-ce qui rend le rapport crédible face à un vendeur ?", a: "Il croise plus de 250 données issues de 13 sources officielles (prix au m² réels DVF, DPE, risques Géorisques, INSEE, environnement). Ce n'est pas votre avis, ce sont des faits vérifiables : la négociation devient factuelle." },
  { q: "Puis-je remettre un rapport à ma marque ?", a: "Oui, l'offre Pro permet un rapport co-brandé (votre nom, votre logo). Le client repart avec un document professionnel qui porte votre image, un vrai outil de closing." },
  { q: "Combien de temps prend une analyse ?", a: "Environ 30 secondes : vous collez le lien d'une annonce, l'outil génère le rapport complet avec un score sur 100." },
  { q: "Puis-je essayer gratuitement ?", a: "Oui. Vous pouvez tester l'outil sur une annonce réelle avant de souscrire. Voir aussi des exemples d'analyses dans le Baromètre." },
];

const jsonLd = [
  {
    "@context": "https://schema.org", "@type": "Service",
    name: "ScoreImmo Pro", serviceType: "Outil d'analyse et d'estimation immobilière pour mandataires",
    provider: { "@type": "Organization", name: "ScoreImmo", url: SITE },
    areaServed: { "@type": "Country", name: "France" },
    description, url: canonical,
  },
  {
    "@context": "https://schema.org", "@type": "FAQPage",
    mainEntity: faq.map(f => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
  },
  {
    "@context": "https://schema.org", "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Accueil", item: `${SITE}/` },
      { "@type": "ListItem", position: 2, name: "ScoreImmo Pro", item: canonical },
    ],
  },
];
---
<BaseLayout {title} {description} {canonical} {jsonLd}>
  <section class="si-section">
    <div class="si-container">
      <nav class="si-breadcrumb" aria-label="Fil d'Ariane">
        <a href="/">Accueil</a><span> &rsaquo; </span><span>ScoreImmo Pro</span>
      </nav>

      <header class="pro-hero">
        <p class="pro-kicker">ScoreImmo Pro . Pour les mandataires</p>
        <h1 class="pro-h1">Votre rapport d'expert immobilier, à votre marque</h1>
        <p class="pro-lead">Estimez juste, décrochez plus de mandats et rassurez vos clients avec une analyse objective sur 100, générée en 30 secondes à partir de 13 sources officielles. Indépendante, donc crédible.</p>
        <div class="pro-actions">
          <a class="pro-btn pro-btn-primary" href={appUrl}>Tester gratuitement</a>
          <a class="pro-btn pro-btn-ghost" href="/barometre">Voir un exemple d'analyse</a>
        </div>
      </header>

      <section class="pro-block">
        <h2 class="pro-h2">Pourquoi les mandataires utilisent ScoreImmo</h2>
        <div class="pro-cards">
          <div class="pro-card"><h3>Objectif et indépendant</h3><p>13 sources officielles croisées (DVF, DPE, Géorisques, INSEE...). Ce n'est pas un avis maison, ce sont des faits : votre estimation devient incontestable.</p></div>
          <div class="pro-card"><h3>À votre marque</h3><p>Remettez un rapport co-brandé, avec votre nom et votre logo. Un document professionnel qui vous valorise et sert d'outil de closing.</p></div>
          <div class="pro-card"><h3>En 30 secondes</h3><p>Collez le lien d'une annonce, obtenez un rapport complet : prix au m² réels, DPE, risques, environnement et un score sur 100.</p></div>
          <div class="pro-card"><h3>Pour décrocher le mandat</h3><p>Transformez la négociation de prix en discussion de données. Le vendeur accepte le bon prix quand il est prouvé.</p></div>
        </div>
      </section>

      <section class="pro-block">
        <h2 class="pro-h2">Comment ça marche</h2>
        <ol class="pro-steps">
          <li><strong>Collez le lien</strong> d'une annonce immobilière (ou saisissez l'adresse).</li>
          <li><strong>Recevez le rapport</strong> complet en 30 secondes : score sur 100, prix vs marché, DPE, risques, environnement, commerces.</li>
          <li><strong>Remettez-le à votre client</strong>, à votre marque, pour justifier le prix et emporter la décision.</li>
        </ol>
      </section>

      <section class="pro-block">
        <AnalyzerBox blog="pro" medium="pro_landing_tool" />
      </section>

      <section class="pro-block">
        <h2 class="pro-h2">Ce que contient chaque rapport</h2>
        <ul class="pro-data">
          <li>Prix au m² réels du secteur (DVF)</li>
          <li>Position vs marché (sur ou sous-évalué)</li>
          <li>Performance énergétique (DPE)</li>
          <li>Risques naturels et technologiques</li>
          <li>Environnement, commerces et transports</li>
          <li>Profil socio-démographique de la commune</li>
          <li>Un score global sur 100 et un verdict</li>
        </ul>
        <p class="pro-note">Découvrez des analyses réelles dans <a href="/barometre">le Baromètre ScoreImmo</a>, et nos guides métier dans <a href="/blogs/pro">l'espace mandataires</a>.</p>
      </section>

      <section class="pro-block pro-pricing">
        <h2 class="pro-h2">L'offre Pro</h2>
        <p>Une offre pensée pour les professionnels, avec rapport co-brandé et analyses illimitées. Découvrez le détail et les tarifs sur notre <a href="/pages/tarifs">page tarifs</a>, ou commencez par tester l'outil gratuitement.</p>
        <div class="pro-actions">
          <a class="pro-btn pro-btn-primary" href={appUrl}>Tester gratuitement</a>
          <a class="pro-btn pro-btn-ghost" href="/pages/tarifs">Voir les tarifs</a>
        </div>
      </section>

      <section class="pro-block">
        <h2 class="pro-h2">Questions fréquentes</h2>
        {faq.map(f => (
          <div class="pro-faq"><h3>{f.q}</h3><p>{f.a}</p></div>
        ))}
      </section>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .si-breadcrumb { font-size: 0.875rem; color: var(--si-muted-foreground, #64748B); margin: 1rem 0 2rem; }
  .si-breadcrumb a { color: var(--si-muted-foreground, #64748B); text-decoration: none; }
  .pro-hero { max-width: 46rem; margin: 0 auto 3rem; text-align: center; }
  .pro-kicker { font-family: var(--si-font-heading,'DM Sans',sans-serif); font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--si-accent,#3B82F6); margin: 0 0 0.75rem; }
  .pro-h1 { font-family: var(--si-font-heading,'DM Sans',sans-serif); font-size: clamp(2rem,5vw,3rem); font-weight: 800; line-height: 1.1; letter-spacing: -0.025em; margin: 0 0 1rem; color: var(--si-foreground); }
  .pro-lead { font-size: 1.15rem; line-height: 1.7; color: var(--si-muted-foreground,#64748B); margin: 0 0 1.75rem; }
  .pro-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; }
  .pro-btn { display: inline-flex; align-items: center; justify-content: center; height: 2.9rem; padding: 0 1.6rem; border-radius: var(--si-radius,0.75rem); font-weight: 600; text-decoration: none; transition: transform .15s, opacity .15s; }
  .pro-btn:hover { transform: translateY(-1px); }
  .pro-btn-primary { background: var(--si-accent,#3B82F6); color: #fff; }
  .pro-btn-ghost { background: var(--si-card,#fff); color: var(--si-foreground); border: 1px solid var(--si-border,#E2E8F0); }
  .pro-block { max-width: 52rem; margin: 0 auto 3rem; }
  .pro-h2 { font-family: var(--si-font-heading,'DM Sans',sans-serif); font-size: clamp(1.5rem,3.5vw,2rem); font-weight: 700; margin: 0 0 1.5rem; text-align: center; color: var(--si-foreground); }
  .pro-cards { display: grid; grid-template-columns: repeat(auto-fit,minmax(230px,1fr)); gap: 1rem; }
  .pro-card { padding: 1.5rem; border: 1px solid var(--si-border,#E2E8F0); border-radius: var(--si-radius-xl,1rem); background: var(--si-card,#fff); }
  .pro-card h3 { font-family: var(--si-font-heading,'DM Sans',sans-serif); font-size: 1.1rem; font-weight: 700; margin: 0 0 0.5rem; color: var(--si-foreground); }
  .pro-card p { margin: 0; line-height: 1.6; color: var(--si-muted-foreground,#64748B); font-size: 0.95rem; }
  .pro-steps { counter-reset: s; list-style: none; padding: 0; display: grid; gap: 1rem; }
  .pro-steps li { position: relative; padding: 1.1rem 1.25rem 1.1rem 3.5rem; border: 1px solid var(--si-border,#E2E8F0); border-radius: var(--si-radius,0.75rem); background: var(--si-card,#fff); line-height: 1.6; }
  .pro-steps li::before { counter-increment: s; content: counter(s); position: absolute; left: 1rem; top: 1.1rem; width: 1.75rem; height: 1.75rem; border-radius: 50%; background: var(--si-accent,#3B82F6); color: #fff; font-weight: 700; display: flex; align-items: center; justify-content: center; }
  .pro-data { columns: 2; column-gap: 2rem; padding-left: 1.2rem; line-height: 1.9; }
  @media (max-width: 520px) { .pro-data { columns: 1; } }
  .pro-note { margin-top: 1.5rem; color: var(--si-muted-foreground,#64748B); }
  .pro-note a, .pro-pricing a { color: var(--si-accent,#3B82F6); }
  .pro-pricing { text-align: center; padding: 2rem; border: 1px solid var(--si-border,#E2E8F0); border-radius: var(--si-radius-xl,1rem); background: var(--si-muted,#F1F5F9); }
  .pro-pricing p { max-width: 38rem; margin: 0 auto 1.5rem; line-height: 1.7; }
  .pro-faq { margin-bottom: 1.25rem; }
  .pro-faq h3 { font-family: var(--si-font-heading,'DM Sans',sans-serif); font-size: 1.05rem; font-weight: 700; margin: 0 0 0.4rem; color: var(--si-foreground); }
  .pro-faq p { margin: 0; line-height: 1.65; color: var(--si-muted-foreground,#64748B); }
</style>
